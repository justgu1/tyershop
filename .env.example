# ---------- Image tags (infra-swarm atualiza automaticamente) ----------
TYERSHOP_BACKEND_TAG=latest
TYERSHOP_FRONTEND_TAG=latest
TYERSHOP_API_TAG=latest

# ---------- Database ----------
MEDUSA_DB_USER=root
MEDUSA_DB_NAME=medusa_db

# ---------- Public storefront ----------
PUBLIC_MEDUSA_URL=https://shop.example.com
PUBLIC_MEDUSA_PUBLISHABLE_KEY=replace_with_publishable_key
# Opcional: região da loja (preços no storefront / Medusa v2)
PUBLIC_MEDUSA_REGION_ID=

# ---------- App integrations ----------
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=replace_with_access_key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=tyershop
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=https://s3.example.com
AWS_URL=https://s3.example.com/tyershop
SMTP_HOST=smtp.example.com
SMTP_PORT=587
NEWSLETTER_FROM=news@tyershop.com
NEWSLETTER_TO=

# ---------- PDP (product.metadata no Medusa) ----------
# Campos opcionais usados em /product/[handle]:
# size_guide_image_url — URL (absoluta ou /public) da imagem do guia de medidas
# model_size_image_url — URL da imagem “medidas do modelo”
# composition | diferenciais | material_composition — texto (composição / diferenciais)
# tech_sheet — JSON array [{"label":"...","value":"..."}] ou objeto { "Chave": "valor" }
# faq_json | pdp_faq — JSON array [{"q":"...","a":"..."}]
# pdp_story_a, pdp_story_b — textos extra para blocos alternados abaixo da dobra