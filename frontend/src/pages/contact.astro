---
import LegalLayout from '../layouts/LegalLayout.astro';
import { getLangFromUrl, t } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const desc = t(lang, 'contact', 'meta_description');
---
<LegalLayout title={t(lang, 'footer', 'contact')} lang={lang} description={desc} wide>
  <div class="contact-page">
    <p class="contact-page__intro">{t(lang, 'contact', 'intro')}</p>

    <div class="contact-page__grid">
      <form class="contact-form" id="contact-form" novalidate>
        <div class="contact-form__row">
          <div class="contact-form__field">
            <label for="c-name">{t(lang, 'contact', 'name')}</label>
            <input type="text" id="c-name" name="name" required autocomplete="name" />
          </div>
          <div class="contact-form__field">
            <label for="c-email">{t(lang, 'contact', 'email')}</label>
            <input type="email" id="c-email" name="email" required autocomplete="email" />
          </div>
        </div>
        <div class="contact-form__field">
          <label for="c-subject">{t(lang, 'contact', 'subject')}</label>
          <input type="text" id="c-subject" name="subject" autocomplete="off" />
        </div>
        <div class="contact-form__field">
          <label for="c-message">{t(lang, 'contact', 'message')}</label>
          <textarea id="c-message" name="message" rows="7" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">{t(lang, 'contact', 'submit')}</button>
        <p id="contact-status" class="contact-form__status" aria-live="polite" hidden></p>
      </form>

      <aside class="contact-aside" aria-labelledby="contact-info-title">
        <h2 id="contact-info-title" class="contact-aside__title">{t(lang, 'contact', 'info_title')}</h2>
        <ul class="contact-aside__list" role="list">
          <li>
            <span class="contact-aside__label">{t(lang, 'contact', 'email_label')}</span>
            <a href="mailto:suporte@tyershop.com">suporte@tyershop.com</a>
          </li>
          <li>
            <span class="contact-aside__label">{t(lang, 'contact', 'instagram_label')}</span>
            <a href="https://www.instagram.com/tyer_br" target="_blank" rel="noopener noreferrer">@tyer_br</a>
          </li>
        </ul>
        <p class="contact-aside__hours">{t(lang, 'contact', 'business_hours')}</p>
      </aside>
    </div>
  </div>
</LegalLayout>

<style>
  .contact-page__intro {
    font-size: 16px;
    line-height: 1.75;
    color: var(--c-muted);
    max-width: 52ch;
    margin-bottom: 8px;
  }
  .contact-page__grid {
    display: grid;
    gap: 40px;
    margin-top: 28px;
    align-items: start;
  }
  @media (min-width: 880px) {
    .contact-page__grid {
      grid-template-columns: minmax(0, 1fr) minmax(260px, 320px);
      gap: 56px 64px;
    }
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
    max-width: none;
  }
  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 560px) {
    .contact-form__row {
      grid-template-columns: 1fr;
    }
  }
  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .contact-form__field label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-muted);
  }
  .contact-form__field input,
  .contact-form__field textarea {
    padding: 12px 14px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    color: var(--c-text);
    font-size: 14px;
    transition: border-color var(--ease);
    resize: vertical;
  }
  .contact-form__field input:focus,
  .contact-form__field textarea:focus {
    outline: none;
    border-color: var(--c-accent);
  }
  .contact-form__status {
    font-size: 13px;
    color: var(--c-accent);
    margin-top: 4px;
  }
  .contact-aside {
    padding: 24px;
    border-radius: var(--r-md);
    border: 1px solid var(--c-border);
    background: var(--c-surface);
  }
  .contact-aside__title {
    font-family: var(--font-title);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-text);
    margin: 0 0 16px;
  }
  .contact-aside__list {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .contact-aside__list li {
    font-size: 14px;
    line-height: 1.5;
    color: var(--c-muted);
    margin: 0;
  }
  .contact-aside__label {
    display: block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-muted);
    margin-bottom: 4px;
  }
  .contact-aside__list a {
    color: var(--c-accent);
    text-decoration: none;
    font-weight: 500;
  }
  .contact-aside__list a:hover {
    text-decoration: underline;
  }
  .contact-aside__hours {
    font-size: 13px;
    line-height: 1.6;
    color: var(--c-muted);
    margin: 0;
    padding-top: 12px;
    border-top: 1px solid var(--c-border);
  }
</style>
<script
  define:vars={{
    contactSending: t(lang, 'contact', 'sending'),
    contactSentOk: t(lang, 'contact', 'sent_ok'),
  }}
>
  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const status = document.getElementById('contact-status');
    if (!status) return;
    status.hidden = false;
    status.textContent = contactSending;
    await new Promise((r) => setTimeout(r, 800));
    status.textContent = contactSentOk;
    const form = e.currentTarget;
    if (form instanceof HTMLFormElement) form.reset();
  });
</script>
