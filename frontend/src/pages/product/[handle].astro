---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getLangFromUrl, t, getPathForLang } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { getMedusaStoreUrl } from '../../lib/medusa-env';
import { getProductListQueryString, getVariantPriceInfo, resolveDefaultRegionId } from '../../lib/medusa-pricing';
import { getVariantSlideUrls } from '../../lib/product-variant-gallery';
import { formatVariationValuesOnly, getProductVariantData } from '../../lib/product-variants';
import { isColorOptionRow } from '../../lib/variant-color-swatches';
import { optionRowKind, swatchFillForValue } from '../../lib/variant-option-ui';
import {
  compositionText,
  metaString,
  parseFaqItems,
  parseProductDetailBlocks,
  parseTechSheetRows,
} from '../../lib/product-pdp-metadata';

/** PDP dinâmica: qualquer `handle` válido na Medusa (não depende só do pré-render). */
export const prerender = false;

const lang: Lang = getLangFromUrl(Astro.url);

const { handle } = Astro.params;
const pk = 'pk_56a7e1a252f159acbc6c590a025dac7a69d4c869fd621f0273ad10c2a87e3975';
const medusaHeaders = { 'x-publishable-api-key': pk };
let product: any = null;
let related: any[] = [];
let newest: any[] = [];

try {
  const url = getMedusaStoreUrl();
  const regionId = await resolveDefaultRegionId(url, medusaHeaders);
  const q = getProductListQueryString(regionId);
  const res = await fetch(
    `${url}/store/products?${q}&handle=${encodeURIComponent(handle ?? '')}&limit=1`,
    { headers: medusaHeaders, signal: AbortSignal.timeout(5000) }
  );
  if (res.ok) {
    const { products } = await res.json();
    product = products?.[0] ?? null;
    if (product?.collection?.id) {
      const rRes = await fetch(
        `${url}/store/products?${q}&collection_id[]=${product.collection.id}&limit=12`,
        { headers: medusaHeaders, signal: AbortSignal.timeout(5000) }
      );
      if (rRes.ok) {
        const { products: rp } = await rRes.json();
        related = (rp ?? []).filter((p: any) => p.handle !== handle).slice(0, 8);
      }
    }
    const newestRes = await fetch(`${url}/store/products?${q}&limit=16`, {
      headers: medusaHeaders,
      signal: AbortSignal.timeout(5000),
    });
    if (newestRes.ok) {
      const { products: np } = await newestRes.json();
      newest = [...(np ?? [])]
        .filter((p: any) => p?.handle && p.handle !== handle)
        .sort(
          (a: any, b: any) =>
            new Date(b?.created_at || 0).getTime() - new Date(a?.created_at || 0).getTime()
        )
        .slice(0, 8);
    }
  }
} catch {}

const productFound = !!product;
if (!productFound) {
  Astro.response.status = 404;
}

const md = (productFound ? (product!.metadata ?? {}) : {}) as Record<string, unknown>;
const dropHandleRaw = productFound
  ? String(product!.metadata?.drop ?? '').trim() || String(product!.collection?.handle ?? '').trim()
  : '';
const dropHandle = dropHandleRaw.toLowerCase().replace(/[^a-z0-9-_]/g, '');
const customDropModules = import.meta.glob('../../components/drops/**/*.astro', { eager: true }) as Record<
  string,
  { default?: any }
>;
const productSpecificKey = `../../components/drops/products/${String(handle ?? '').toLowerCase()}.astro`;
const dropProductKey = dropHandle
  ? `../../components/drops/${dropHandle}/${String(handle ?? '').toLowerCase()}.astro`
  : '';
const dropPageKey = dropHandle ? `../../components/drops/${dropHandle}.astro` : '';
const CustomDropComponent =
  customDropModules[productSpecificKey]?.default ||
  (dropProductKey ? customDropModules[dropProductKey]?.default : null) ||
  (dropPageKey ? customDropModules[dropPageKey]?.default : null) ||
  null;

const {
  stockReliable,
  normalizedVariants: normalizedVariantsRaw,
  optionRows,
  defaultVariant,
  defaultVariantTitle,
} = productFound
  ? getProductVariantData(product!)
  : {
      stockReliable: false,
      normalizedVariants: [],
      optionRows: [],
      defaultVariant: null,
      defaultVariantTitle: '',
    };

const variantById = productFound
  ? new Map<string, any>((product!.variants ?? []).map((v: any) => [String(v.id ?? ''), v]))
  : new Map<string, any>();

function optionRowRank(title: string): number {
  const k = optionRowKind(title);
  if (k === 'color') return 0;
  if (k === 'size') return 1;
  return 2;
}
const optionRowsDisplay = productFound
  ? [...optionRows].sort((a, b) => {
      const d = optionRowRank(a.title) - optionRowRank(b.title);
      return d !== 0 ? d : a.title.localeCompare(b.title);
    })
  : [];

function pdpSwatchInnerStyle(val: string) {
  const { fill, isGradient } = swatchFillForValue(val);
  const out: { background?: string; backgroundColor?: string } = {};
  if (isGradient && fill) out.background = fill;
  else if (fill) out.backgroundColor = fill;
  return out;
}

function pdpSwatchIsLight(val: string) {
  const { fill, isGradient } = swatchFillForValue(val);
  return (
    !!fill &&
    !isGradient &&
    ['#f5f5f5', '#ffffff', '#fff', '#f0f0f0', '#faf5eb'].includes(fill.toLowerCase())
  );
}

const defaultPriceInfo = productFound ? getVariantPriceInfo(defaultVariant) : null;
const defaultNorm =
  normalizedVariantsRaw.find((n) => n.id === defaultVariant?.id) ?? normalizedVariantsRaw[0];
const initialSlides = productFound
  ? getVariantSlideUrls(defaultVariant, product!)
  : ['/logo.webp'];
const defaultMaxQty = defaultNorm?.maxQty;
const defaultMaxQtyAttr =
  defaultMaxQty != null && Number.isFinite(Number(defaultMaxQty)) ? String(Math.max(0, Math.floor(Number(defaultMaxQty)))) : '';
const defaultDiscountPct = defaultNorm?.discountPercent ?? 0;
const variationValuesLine = formatVariationValuesOnly(defaultVariant, optionRows);
const pdpVariantsPayload = normalizedVariantsRaw.map((v) => ({
  id: v.id,
  title: v.title,
  price: v.price,
  soldOut: v.soldOut,
  maxQty: v.maxQty,
  options: v.options,
  images: v.images,
  slideUrls: v.slideUrls,
  priceDisplay: v.priceDisplay,
  originalDisplay: v.originalDisplay,
  discountPercent: v.discountPercent,
  allowBackorder: v.allowBackorder === true,
}));

const stockMsgs = {
  out: t(lang, 'pdp', 'stock_out'),
  backorder: t(lang, 'pdp', 'stock_backorder'),
  unverified: t(lang, 'pdp', 'stock_unverified'),
  available: t(lang, 'pdp', 'stock_available'),
  units: t(lang, 'pdp', 'stock_units'),
};

function initialStockLine(): string {
  if (!productFound || !defaultNorm) return '';
  if (defaultNorm.soldOut) return stockMsgs.out;
  const raw = variantById.get(defaultNorm.id);
  if (raw?.allow_backorder === true) return stockMsgs.backorder;
  if (!stockReliable) return stockMsgs.unverified;
  if (defaultNorm.maxQty != null && defaultNorm.maxQty > 0) {
    return stockMsgs.units.replace('{count}', String(defaultNorm.maxQty));
  }
  return stockMsgs.available;
}

const galleryImages = productFound
  ? product!.images ?? (product!.thumbnail ? [{ url: product!.thumbnail }] : [])
  : [];
const sizeGuideUrl = metaString(md, 'size_guide_image_url');
const modelSizeUrl = metaString(md, 'model_size_image_url');
const composition = compositionText(md);
const techRows = parseTechSheetRows(md);
const faqItemsRaw = parseFaqItems(md);
const faqItems =
  faqItemsRaw.length > 0
    ? faqItemsRaw
    : [
        { q: t(lang, 'pdp', 'faq_default_q1'), a: t(lang, 'pdp', 'faq_default_a1') },
        { q: t(lang, 'pdp', 'faq_default_q2'), a: t(lang, 'pdp', 'faq_default_a2') },
      ];

const productDetailBlocksRaw = parseProductDetailBlocks(md);
const productDescriptionPlain =
  productFound && typeof product!.description === 'string' ? product!.description.trim() : '';
let productDetailBlocks = productDetailBlocksRaw;
if (productDetailBlocks.length === 0 && productDescriptionPlain) {
  productDetailBlocks = [{ title: t(lang, 'pdp', 'about_product_fallback'), body: productDescriptionPlain }];
}

const sizeGuideOpensNewTab = sizeGuideUrl ? /^https?:\/\//i.test(sizeGuideUrl) : false;

const imgUrl = (i: number) => galleryImages[i]?.url ?? null;
const storyA = productFound
  ? metaString(md, 'pdp_story_a') ?? product!.description ?? t(lang, 'product', 'inspiration_text')
  : '';
const storyB = productFound
  ? metaString(md, 'pdp_story_b') ?? product!.description ?? t(lang, 'product', 'feature_1')
  : '';

const jsonLd = productFound
  ? {
      '@context': 'https://schema.org',
      '@type': 'Product',
      name: product!.title,
      description: product!.description,
      image: galleryImages.map((i: any) => `https://tyer.com.br${i.url}`),
      brand: { '@type': 'Brand', name: 'Tyer' },
      ...(defaultPriceInfo && {
        offers: {
          '@type': 'Offer',
          price: defaultPriceInfo.amountCents / 100,
          priceCurrency: defaultPriceInfo.currency,
          availability: 'https://schema.org/InStock',
        },
      }),
    }
  : null;
---

<Layout
  title={productFound ? product!.title : 'Produto não encontrado'}
  description={productFound ? (product!.description ?? 'Limited edition streetwear piece by Tyer.') : 'Esta página não existe ou o produto foi removido.'}
  lang={lang}
  ogImage={productFound ? (product!.thumbnail ?? '/logo.webp') : '/logo.webp'}
  ogType="product"
  jsonLd={jsonLd ?? undefined}
  noindex={!productFound}
  bodyClass="pdp-body"
>
  {productFound ? (
    <>
  <section
    class="pdp-hero"
    data-pdp-root
    data-product-id={product!.id}
    data-product-handle={product!.handle}
    data-product-title={product!.title ?? ''}
    data-stock-reliable={stockReliable ? 'true' : 'false'}
    data-stock-msgs={JSON.stringify(stockMsgs)}
    data-stock-notify-msgs={JSON.stringify({
      ok: t(lang, 'pdp', 'stock_notify_ok'),
      err: t(lang, 'pdp', 'stock_notify_err'),
    })}
    data-variants={encodeURIComponent(JSON.stringify(pdpVariantsPayload))}
    data-option-rows={encodeURIComponent(JSON.stringify(optionRows))}
    aria-labelledby="pdp-title"
  >
    <div class="pdp-hero__fold">
    <div class="pdp-hero__media">
      <div class="pdp-hero__media-carousel-block">
        <div class="pdp-hero__thumbs-rail-wrap">
          <div class="pdp-hero__thumbs-rail" id="pdp-thumbs-rail" role="tablist" aria-label={t(lang, 'pdp', 'gallery_thumbs')}>
            {initialSlides.map((url: string, i: number) => (
              <button
                type="button"
                class:list={['pdp-hero__thumb', { 'is-active': i === 0 }]}
                data-slide-idx={i}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-label={`${t(lang, 'pdp', 'slide')} ${i + 1}`}
              >
                <img src={url} alt="" width="72" height="72" loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
              </button>
            ))}
          </div>
        </div>
        <div class="pdp-hero__stage">
          <button type="button" class="pdp-hero__nav pdp-hero__nav--prev" id="pdp-carousel-prev" aria-label={t(lang, 'pdp', 'prev_slide')}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <div class="pdp-hero__main">
            <div class="pdp-hero__main-carousel" id="pdp-main-carousel">
              <span
                class="pdp-main-discount"
                id="pdp-main-discount"
                hidden={defaultDiscountPct <= 0}
              >
                {defaultDiscountPct > 0 ? `−${defaultDiscountPct}%` : ''}
              </span>
              <button
                type="button"
                class="pdp-hero__main-img-wrap"
                id="pdp-main-img-wrap"
                aria-label={t(lang, 'pdp', 'gallery_fullscreen')}
              >
                <img
                  id="pdp-main-img"
                  src={initialSlides[0] ?? '/logo.webp'}
                  alt={product.title}
                  class="pdp-hero__main-img"
                  width="900"
                  height="1125"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              </button>
            </div>
          </div>
          <button type="button" class="pdp-hero__nav pdp-hero__nav--next" id="pdp-carousel-next" aria-label={t(lang, 'pdp', 'next_slide')}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    </div>

    <div class="pdp-hero__buy-col">
      <div class="pdp-hero__sidebar-stack">
      <div class="pdp-buy-card" data-pdp-buy-card>
        <nav class="pdp-breadcrumb" aria-label="Breadcrumb">
          <ol class="pdp-breadcrumb__list">
            <li><a href={getPathForLang('/', lang)}>Tyer</a></li>
            <li aria-hidden="true">/</li>
            {product.collection?.handle ? (
              <>
                <li>
                  <a href={getPathForLang(`/collections/${product.collection.handle}`, lang)}>
                    {product.collection.title ?? product.collection.handle}
                  </a>
                </li>
                <li aria-hidden="true">/</li>
                <li aria-current="page">{product.title}</li>
              </>
            ) : (
              <>
                <li>
                  <a href={getPathForLang('/shop', lang)}>{t(lang, 'nav', 'shop')}</a>
                </li>
                <li aria-hidden="true">/</li>
                <li aria-current="page">{product.title}</li>
              </>
            )}
          </ol>
        </nav>

        {product.metadata?.badge && <span class="pdp-badge">{String(product.metadata.badge)}</span>}
        <h1 class="pdp-title" id="pdp-title">{product.title}</h1>

        {optionRows.length > 0 && (
          <>
            <p class="pdp-variation-heading" id="pdp-variation-heading">
              <span class="pdp-variation-heading__label">{t(lang, 'pdp', 'variation_label')}</span>{' '}
              <span class="pdp-variation-heading__value" id="pdp-variation-value">
                {variationValuesLine || defaultVariantTitle}
              </span>
            </p>
            <div class="pdp-variants" role="group" aria-label={t(lang, 'product', 'select_size')}>
              {optionRowsDisplay.map((row: { id: string; title: string; values: string[] }, idx: number) => {
                const prev = optionRowsDisplay[idx - 1];
                const showDivider =
                  idx > 0 &&
                  prev &&
                  optionRowKind(prev.title) === 'color' &&
                  optionRowKind(row.title) === 'size';
                const colorRow = isColorOptionRow(row.title);
                return (
                  <>
                    {showDivider && <div class="pdp-variants-divider" role="presentation" aria-hidden="true" />}
                    <div class="pdp-variant-row">
                      <p class="pdp-label">{row.title}</p>
                      <div
                        class:list={['pdp-variant-values', { 'pdp-variant-values--swatch': colorRow }]}
                        role="radiogroup"
                        aria-label={row.title}
                      >
                        {row.values.map((val: string) => {
                          const sel = (defaultVariant?.options ?? []).find(
                            (o: any) => String(o.option_id ?? o.id) === row.id
                          );
                          const isSel = String(sel?.value ?? '') === val;
                          if (colorRow) {
                            const { fill } = swatchFillForValue(val);
                            return (
                              <button
                                type="button"
                                class:list={[
                                  'pdp-variant-btn',
                                  'pdp-variant-btn--swatch',
                                  'pdp-variant-btn--color',
                                  {
                                    'is-selected': isSel,
                                    'is-unavailable': false,
                                    'pdp-variant-btn--swatch-neutral': !fill,
                                    'pdp-variant-btn--swatch-light': pdpSwatchIsLight(val),
                                  },
                                ]}
                                data-option-id={row.id}
                                data-option-value={val}
                                title={val}
                                aria-label={`${row.title}: ${val}`}
                                aria-checked={isSel ? 'true' : 'false'}
                              >
                                <span class="pdp-variant-swatch-inner" style={pdpSwatchInnerStyle(val)} />
                                <span class="pdp-variant-btn-text pdp-variant-btn-text--sr">{val}</span>
                                <span class="pdp-variant-x" aria-hidden="true">×</span>
                              </button>
                            );
                          }
                          return (
                            <button
                              type="button"
                              class:list={['pdp-variant-btn', { 'is-selected': isSel, 'is-unavailable': false }]}
                              data-option-id={row.id}
                              data-option-value={val}
                              aria-checked={isSel ? 'true' : 'false'}
                            >
                              <span class="pdp-variant-btn-text">{val}</span>
                              <span class="pdp-variant-x" aria-hidden="true">×</span>
                            </button>
                          );
                        })}
                      </div>
                    </div>
                  </>
                );
              })}
            </div>
            {sizeGuideUrl && (
              <p class="pdp-size-chart-row">
                <a
                  href={sizeGuideUrl}
                  class="pdp-size-chart-link"
                  target={sizeGuideOpensNewTab ? '_blank' : undefined}
                  rel={sizeGuideOpensNewTab ? 'noopener noreferrer' : undefined}
                >
                  {t(lang, 'pdp', 'size_chart')}
                </a>
              </p>
            )}
          </>
        )}

        <div class="pdp-measure-btns">
          {modelSizeUrl && (
            <button type="button" class="pdp-pill-btn pdp-pill-btn--ghost" id="pdp-open-model" data-modal-target="pdp-modal-model">
              {t(lang, 'pdp', 'model_measures')}
            </button>
          )}
        </div>

        <div class="pdp-price-qty-row" id="pdp-price-qty-row">
          <div class="pdp-price-block" id="pdp-price-block">
            <span
              class="pdp-price-striked"
              id="pdp-price-original"
              hidden={!defaultPriceInfo?.originalDisplay}
            >
              {defaultPriceInfo?.originalDisplay ?? ''}
            </span>
            <span class="pdp-price-current" id="pdp-price-current">{defaultPriceInfo?.display ?? ''}</span>
          </div>
          <div class="pdp-qty-wrap" role="group" aria-label={t(lang, 'pdp', 'qty_label')}>
            <button type="button" class="pdp-qty-btn" id="pdp-qty-dec" aria-label={t(lang, 'pdp', 'qty_dec')}>−</button>
            <input
              id="pdp-qty-input"
              class="pdp-qty-input"
              type="number"
              min="1"
              step="1"
              value="1"
              inputmode="numeric"
              pattern="[0-9]*"
              aria-label={t(lang, 'pdp', 'qty_label')}
            />
            <button type="button" class="pdp-qty-btn" id="pdp-qty-inc" aria-label={t(lang, 'pdp', 'qty_inc')}>+</button>
          </div>
        </div>

        <p class="pdp-stock" id="pdp-stock-line" role="status">{initialStockLine()}</p>

        <div class="pdp-stock-notify" id="pdp-stock-notify" hidden>
          <p class="pdp-stock-notify__intro">{t(lang, 'pdp', 'stock_notify_intro')}</p>
          <div class="pdp-stock-notify__row">
            <input
              type="email"
              class="pdp-stock-notify__input"
              id="pdp-stock-notify-email"
              autocomplete="email"
              inputmode="email"
              placeholder="email@exemplo.com"
              aria-label={t(lang, 'pdp', 'stock_notify_email_aria')}
            />
            <button type="button" class="btn btn-outline pdp-stock-notify__btn" id="pdp-stock-notify-submit">
              {t(lang, 'pdp', 'stock_notify_cta')}
            </button>
          </div>
          <p class="pdp-stock-notify__feedback" id="pdp-stock-notify-feedback" hidden role="status"></p>
        </div>

        <div class="pdp-buy-actions">
          <button type="button" class="btn btn-primary pdp-buy-now" id="pdp-buy-now">
            {t(lang, 'pdp', 'buy_now')}
          </button>
          <button
            type="button"
            class="btn pdp-atc-icon"
            id="pdp-atc"
            data-variant-id={defaultVariant?.id}
            data-title={product.title}
            data-price={defaultPriceInfo?.amountCents ?? ''}
            data-thumbnail={initialSlides[0] ?? product.thumbnail ?? ''}
            data-variant-title={defaultVariantTitle}
            data-max-qty={defaultMaxQtyAttr}
            data-qty="1"
            aria-label={t(lang, 'product', 'add_to_cart')}
          >
            <img src="/icons/quick-cart.svg" alt="" width="22" height="22" />
          </button>
        </div>

        <div class="pdp-shipping" id="pdp-shipping-block">
          <label class="pdp-label" for="pdp-cep-input">{t(lang, 'pdp', 'shipping_cep')}</label>
          <div class="pdp-cep-row">
            <input
              id="pdp-cep-input"
              class="pdp-cep-input"
              type="text"
              inputmode="numeric"
              autocomplete="postal-code"
              maxlength="9"
              placeholder="00000-000"
              aria-describedby="pdp-cep-hint"
            />
          </div>
          <p id="pdp-cep-hint" class="pdp-cep-hint" role="status"></p>
          <p class="pdp-cep-static">{t(lang, 'pdp', 'shipping_estimate_placeholder')}</p>
        </div>
      </div>

        {(composition || techRows.length > 0) && (
          <div class="pdp-characteristics">
            {composition && (
              <details class="pdp-details">
                <summary>{t(lang, 'pdp', 'differentials')}</summary>
                <div class="pdp-details__body">
                  <p class="pdp-composition">{composition}</p>
                </div>
              </details>
            )}

            {techRows.length > 0 && (
              <details class="pdp-details">
                <summary>{t(lang, 'pdp', 'tech_sheet')}</summary>
                <dl class="pdp-tech-dl">
                  {techRows.map((row) => (
                    <>
                      <dt>{row.label}</dt>
                      <dd>{row.value}</dd>
                    </>
                  ))}
                </dl>
              </details>
            )}
          </div>
        )}
      </div>
    </div>
    </div>

    {related.length > 0 && (
      <section class="pdp-hero__drop-rail" aria-labelledby="pdp-drop-rail-title">
        <div class="pdp-hero__drop-rail-inner">
          <h2 class="pdp-hero__drop-rail-title" id="pdp-drop-rail-title">
            {t(lang, 'pdp', 'drop_section_title')}
            {product.collection?.title && (
              <span class="pdp-hero__drop-rail-sub"> — {product.collection.title}</span>
            )}
          </h2>
          <div class="shop-col-carousel-wrap pdp-shop-carousel-wrap">
            <button
              type="button"
              class="shop-col-carousel__nav shop-col-carousel__nav--prev"
              data-col-nav="prev"
              data-target="pdp-hero-drop-carousel"
              aria-label={t(lang, 'pdp', 'prev_slide')}
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m15 18-6-6 6-6" />
              </svg>
            </button>
            <div class="shop-col-carousel pdp-shop-carousel" id="pdp-hero-drop-carousel" role="region" tabindex="0">
              <div class="shop-col-carousel__track" role="list">
                {related.map((p) => (
                  <div class="shop-col-carousel__cell" role="listitem">
                    <ProductCard product={p} lang={lang} />
                  </div>
                ))}
              </div>
            </div>
            <button
              type="button"
              class="shop-col-carousel__nav shop-col-carousel__nav--next"
              data-col-nav="next"
              data-target="pdp-hero-drop-carousel"
              aria-label={t(lang, 'pdp', 'next_slide')}
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m9 18 6-6-6-6" />
              </svg>
            </button>
          </div>
        </div>
      </section>
    )}

    <div class="pdp-sticky-bar pdp-sticky-bar--offscreen" id="pdp-sticky-bar" aria-hidden="true">
      <button type="button" class="pdp-sticky-bar__fab" id="pdp-sticky-back-top" aria-label={t(lang, 'pdp', 'sticky_back_top')}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          ><path d="m18 15-6-6-6-6" /></svg
        >
      </button>
      <div class="pdp-sticky-bar__sheet">
        <div class="pdp-sticky-bar__head">
          <button
            type="button"
            class="pdp-sticky-bar__menu"
            id="pdp-sticky-menu"
            aria-expanded="false"
            aria-controls="pdp-sticky-drawer"
            aria-label={t(lang, 'pdp', 'sticky_more_options')}
            data-label-open={t(lang, 'pdp', 'sticky_more_options')}
            data-label-close={t(lang, 'pdp', 'sticky_close_options')}
          >
            <span class="pdp-sticky-bar__menu-bars" aria-hidden="true" />
          </button>
          <div class="pdp-sticky-bar__head-price" id="pdp-sticky-price-block">
            <span class="pdp-sticky-bar__price-striked" id="pdp-sticky-price-original" hidden />
            <span class="pdp-sticky-bar__price-current" id="pdp-sticky-price-current" />
          </div>
          <div class="pdp-sticky-bar__head-actions">
            <button type="button" class="btn btn-primary pdp-sticky-bar__buy" id="pdp-sticky-buy-now">
              {t(lang, 'pdp', 'buy_now')}
            </button>
            <button
              type="button"
              class="btn pdp-atc-icon pdp-sticky-bar__atc"
              id="pdp-sticky-atc"
              aria-label={t(lang, 'product', 'add_to_cart')}
            >
              <img src="/icons/quick-cart.svg" alt="" width="22" height="22" />
            </button>
          </div>
        </div>
        <div class="pdp-sticky-bar__drawer" id="pdp-sticky-drawer" hidden>
          <div class="pdp-sticky-bar__variants" id="pdp-sticky-variants-mount" />
          <div class="pdp-sticky-bar__ship">
            <label class="pdp-sticky-bar__cep-label" for="pdp-cep-input-sticky">{t(lang, 'pdp', 'shipping_cep')}</label>
            <input
              id="pdp-cep-input-sticky"
              class="pdp-cep-input pdp-cep-input--sticky"
              type="text"
              inputmode="numeric"
              autocomplete="postal-code"
              maxlength="9"
              placeholder="00000-000"
              aria-describedby="pdp-cep-hint"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="pdp-below-fold">
    {(productDetailBlocks.length > 0 || faqItems.length > 0) && (
      <section
        class="pdp-accordion-row section container"
        aria-label={`${t(lang, 'pdp', 'product_details_title')} · ${t(lang, 'pdp', 'faq_title')}`}
      >
        <div
          class:list={[
            'pdp-accordion-row__grid',
            { 'pdp-accordion-row__grid--split': productDetailBlocks.length > 0 && faqItems.length > 0 },
          ]}
        >
          {productDetailBlocks.length > 0 && (
            <div class="pdp-accordion-row__col">
              <h2 class="section__title" id="pdp-product-details-title">{t(lang, 'pdp', 'product_details_title')}</h2>
              <div class="pdp-faq__list">
                {productDetailBlocks.map((b) => (
                  <details class="pdp-faq__item">
                    <summary>{b.title}</summary>
                    <div class="pdp-faq__a pdp-faq__a--rich" set:html={b.body} />
                  </details>
                ))}
              </div>
            </div>
          )}
          {faqItems.length > 0 && (
            <div class="pdp-accordion-row__col">
              <h2 class="section__title" id="pdp-faq-title">{t(lang, 'pdp', 'faq_title')}</h2>
              <div class="pdp-faq__list">
                {faqItems.map((item) => (
                  <details class="pdp-faq__item">
                    <summary>{item.q}</summary>
                    <div class="pdp-faq__a pdp-faq__a--rich" set:html={item.a} />
                  </details>
                ))}
              </div>
            </div>
          )}
        </div>
      </section>
    )}

    {imgUrl(1) && (
      <section class="pdp-split pdp-split--text-left container">
        <div class="pdp-split__text">
          <p class="section-label">01 — {t(lang, 'product', 'inspiration')}</p>
          <h2 class="pdp-split__title">{t(lang, 'product', 'inspiration')}</h2>
          <div class="pdp-split__body pdp-faq__a--rich" set:html={storyA} />
        </div>
        <div class="pdp-split__img">
          <img src={imgUrl(1)!} alt="" width="640" height="800" loading="lazy" decoding="async" />
        </div>
      </section>
    )}

    {imgUrl(2) && (
      <section class="pdp-split pdp-split--img-left container">
        <div class="pdp-split__img">
          <img src={imgUrl(2)!} alt="" width="640" height="800" loading="lazy" decoding="async" />
        </div>
        <div class="pdp-split__text">
          <p class="section-label">02 — {t(lang, 'product', 'features')}</p>
          <h2 class="pdp-split__title">{t(lang, 'product', 'features')}</h2>
          <div class="pdp-split__body pdp-faq__a--rich" set:html={storyB} />
        </div>
      </section>
    )}

    {imgUrl(3) && (
      <section class="pdp-fullbleed" aria-hidden="false">
        <img src={imgUrl(3)!} alt="" class="pdp-fullbleed__img" width="1440" height="720" loading="lazy" decoding="async" />
        <div class="pdp-fullbleed__cap container">
          <h2 class="pdp-fullbleed__title">03 — {t(lang, 'product', 'street')}</h2>
        </div>
      </section>
    )}

  </div>

  {CustomDropComponent && (
    <CustomDropComponent product={product!} lang={lang} related={related} newest={newest} />
  )}

  {newest.length > 0 && (
    <section class="pdp-related" aria-labelledby="newest-title">
      <div class="container">
        <h2 class="section__title" id="newest-title">{t(lang, 'shop', 'section_novos')}</h2>
        <div class="products-showcase-wrap pdp-related__showcase-wrap">
          <button
            type="button"
            class="products-showcase-nav products-showcase-nav--prev"
            id="pdp-newest-nav-prev"
            aria-label={t(lang, 'pdp', 'prev_slide')}
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"
              ><path d="m15 18-6-6 6-6" /></svg
            >
          </button>
          <div class="products-showcase-viewport" id="pdp-newest-viewport" role="region" aria-label={t(lang, 'shop', 'section_novos')}>
            <div class="products-showcase" role="list">
              {newest.map((p) => (
                <ProductCard product={p} lang={lang} role="listitem" />
              ))}
            </div>
          </div>
          <button
            type="button"
            class="products-showcase-nav products-showcase-nav--next"
            id="pdp-newest-nav-next"
            aria-label={t(lang, 'pdp', 'next_slide')}
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"
              ><path d="m9 18 6-6-6-6" /></svg
            >
          </button>
        </div>
      </div>
    </section>
  )}

  {sizeGuideUrl && (
    <dialog class="pdp-dialog" id="pdp-modal-size-guide" aria-label={t(lang, 'pdp', 'size_guide')}>
      <button type="button" class="pdp-dialog__close" data-close-modal>&times;</button>
      <img src={sizeGuideUrl} alt="" class="pdp-dialog__img" />
    </dialog>
  )}
  {modelSizeUrl && (
    <dialog class="pdp-dialog" id="pdp-modal-model" aria-label={t(lang, 'pdp', 'model_measures')}>
      <button type="button" class="pdp-dialog__close" data-close-modal>&times;</button>
      <img src={modelSizeUrl} alt="" class="pdp-dialog__img" />
    </dialog>
  )}
    <dialog class="pdp-lightbox" id="pdp-lightbox" aria-modal="true" aria-label={t(lang, 'pdp', 'gallery_fullscreen')}>
      <button
        type="button"
        class="pdp-lightbox__backdrop"
        data-close-modal
        tabindex="-1"
        aria-label={t(lang, 'pdp', 'lightbox_close')}
      />
      <button type="button" class="pdp-lightbox__close" data-close-modal aria-label={t(lang, 'pdp', 'lightbox_close')}>
        &times;
      </button>
      <div class="pdp-lightbox__shell">
        <div class="pdp-lightbox__row">
          <button
            type="button"
            class="pdp-lightbox__nav pdp-lightbox__nav--prev"
            id="pdp-lightbox-prev"
            aria-label={t(lang, 'pdp', 'lightbox_prev')}
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              ><path d="m15 18-6-6 6-6" /></svg
            >
          </button>
          <div class="pdp-lightbox__inner">
            <img id="pdp-lightbox-img" src="" alt="" class="pdp-lightbox__img" width="1200" height="1500" />
            <p class="pdp-lightbox__counter" id="pdp-lightbox-counter" aria-live="polite"></p>
          </div>
          <button
            type="button"
            class="pdp-lightbox__nav pdp-lightbox__nav--next"
            id="pdp-lightbox-next"
            aria-label={t(lang, 'pdp', 'lightbox_next')}
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              ><path d="m9 18 6-6-6-6" /></svg
            >
          </button>
        </div>
        <div
          class="pdp-lightbox__thumbs"
          id="pdp-lightbox-thumbs"
          role="tablist"
          aria-label={t(lang, 'pdp', 'gallery_thumbs')}
        />
      </div>
    </dialog>
    </>
  ) : (
    <section class="nf">
      <p class="nf__code">404</p>
      <h1 class="nf__title">{t(lang, 'pdp', 'product_not_found_title')}</h1>
      <p class="nf__sub">{t(lang, 'pdp', 'product_not_found_sub')}</p>
      <div class="nf__actions">
        <a href={getPathForLang('/', lang)} class="btn btn-primary">{t(lang, 'pdp', 'product_not_found_home')}</a>
        <a href={getPathForLang('/shop', lang)} class="btn btn-outline">{t(lang, 'pdp', 'product_not_found_shop')}</a>
      </div>
    </section>
  )}
</Layout>

<style>
  .pdp-hero {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    min-height: 0;
    padding: 24px clamp(12px, 4vw, 40px) 40px;
    margin-inline: auto;
    width: 100%;
    min-width: 0;
    max-width: min(1600px, 100%);
    overflow-x: clip;
    gap: 0;
  }
  @media (max-width: 1024px) {
    .pdp-hero {
      padding-inline: clamp(12px, 4vw, 24px);
    }
  }

  /** Primeira dobra: galeria + card de compra = 75svh (o rail “Colecione o drop” fica abaixo). */
  .pdp-hero__fold {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, min(520px, 100%));
    gap: clamp(16px, 3vw, 40px);
    align-items: stretch;
    box-sizing: border-box;
    height: 75svh;
    min-height: 0;
    max-height: 75svh;
    min-width: 0;
    width: 100%;
  }
  @media (max-width: 1024px) {
    .pdp-hero__fold {
      grid-template-columns: 1fr;
      grid-template-rows: minmax(0, 1fr) auto;
      height: auto;
      min-height: 75svh;
      max-height: none;
    }
  }

  .pdp-hero__media {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-height: 0;
    height: 100%;
    align-items: stretch;
    min-width: 0;
    max-width: 100%;
  }

  .pdp-hero__media-carousel-block {
    display: flex;
    gap: 12px;
    flex: 1 1 auto;
    min-height: 0;
    height: 100%;
    max-height: 100%;
    align-items: stretch;
    min-width: 0;
    max-width: 100%;
  }
  @media (max-width: 1024px) {
    .pdp-hero__media {
      min-height: 0;
      max-height: min(52svh, 520px);
    }
    .pdp-hero__media-carousel-block {
      flex-direction: column-reverse;
      flex: 1 1 auto;
      min-height: 0;
      max-height: 100%;
    }
  }

  .pdp-hero__drop-rail {
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--c-border);
    padding-top: clamp(12px, 2vw, 20px);
    min-width: 0;
    max-width: 100%;
    overflow-x: visible;
    overflow-y: visible;
  }
  .pdp-hero__drop-rail-inner {
    width: 100%;
    min-width: 0;
    max-width: 100%;
  }
  .pdp-hero__drop-rail-title {
    font-family: var(--font-title);
    font-size: clamp(14px, 1.4vw, 18px);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 12px;
    color: var(--c-text);
    overflow-wrap: anywhere;
    word-break: break-word;
    max-width: 100%;
    line-height: 1.25;
    padding-block: 2px;
  }
  .pdp-hero__drop-rail-sub {
    font-weight: 500;
    color: var(--c-muted);
    text-transform: none;
  }

  /**
   * Carrosséis “Colecione o drop” e “Mais novos”: mesmo padrão da loja
   * (`shop-col-carousel-wrap` + track + células + nav).
   */
  .pdp-shop-carousel-wrap.shop-col-carousel-wrap {
    position: relative;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding: 0 44px 10px;
    scrollbar-color: var(--c-border) transparent;
    border-radius: 0;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel::-webkit-scrollbar {
    height: 8px;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel::-webkit-scrollbar-thumb {
    background: #2a2a2a;
    border-radius: 999px;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__track {
    display: flex;
    gap: 20px;
    align-items: stretch;
    width: max-content;
    min-width: 100%;
    min-height: 1px;
    padding: 2px 2px 4px;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell {
    flex: 0 0 clamp(220px, 38vw, 400px);
    min-width: 0;
    scroll-snap-align: start;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc) {
    min-height: 100%;
    height: auto;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc__img-wrap) {
    aspect-ratio: 1;
    width: 100%;
    margin-bottom: 10px;
    border: none;
    border-radius: var(--r, 8px);
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc__img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc__body) {
    flex: 1;
    min-height: 0;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc__name) {
    font-size: 13px;
    min-height: 0;
    -webkit-line-clamp: 2;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc__bottom) {
    margin-top: 6px;
    padding-bottom: 0;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc__price-current) {
    font-size: 13px;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc__price-striked) {
    font-size: 10px;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc__quick-add) {
    width: 30px;
    height: 30px;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc__variants) {
    margin-top: 6px;
    margin-bottom: 4px;
    gap: 4px;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc__variant-hit--size) {
    height: 24px;
    min-width: 28px;
    font-size: 9px;
    padding: 0 6px;
    border-radius: 6px;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc__variant-hit--swatch) {
    width: 22px;
    height: 22px;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc__variant-swatch-inner) {
    width: 16px;
    height: 16px;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__cell :global(.pc__variant-heading) {
    font-size: 10px;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__nav {
    position: absolute;
    top: 46%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    color: #fff;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background var(--ease), border-color var(--ease), transform var(--ease);
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__nav:hover {
    background: rgba(0, 0, 0, 0.9);
    border-color: rgba(255, 255, 255, 0.32);
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__nav:active {
    transform: translateY(-50%) scale(0.97);
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__nav--prev {
    left: 8px;
  }
  .pdp-shop-carousel-wrap .shop-col-carousel__nav--next {
    right: 8px;
  }

  /** «Mais novos»: mesmo carrossel que “Mais vendidos” na home (`products-showcase-*`). */
  .pdp-related .pdp-related__showcase-wrap {
    position: relative;
    width: 100%;
    min-width: 0;
  }
  .pdp-related .products-showcase-nav {
    display: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  @media (min-width: 561px) {
    .pdp-related .products-showcase-nav {
      display: flex;
    }
  }
  .pdp-related .products-showcase-nav:hover {
    background: rgba(0, 0, 0, 0.85);
    border-color: var(--c-accent);
  }
  .pdp-related .products-showcase-nav--prev {
    left: 4px;
  }
  .pdp-related .products-showcase-nav--next {
    right: 4px;
  }
  .pdp-related .products-showcase-viewport {
    width: 100%;
    min-width: 0;
  }
  .pdp-related .products-showcase {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    align-items: stretch;
  }
  .pdp-related .products-showcase > :global(*) {
    min-width: 0;
  }
  @media (max-width: 900px) {
    .pdp-related .products-showcase {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .pdp-related .products-showcase-nav {
      display: flex;
      position: relative;
      top: auto;
      transform: none;
      align-self: center;
      flex-shrink: 0;
    }
    .pdp-related .pdp-related__showcase-wrap {
      display: flex;
      flex-direction: row;
      align-items: stretch;
      gap: 8px;
      margin-inline: -20px;
      padding-inline: 20px;
      min-width: 0;
    }
    .pdp-related .products-showcase-viewport {
      flex: 1;
      min-width: 0;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 10px;
      scrollbar-width: thin;
