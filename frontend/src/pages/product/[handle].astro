      flex: none;
      max-height: 96px;
      width: 100%;
    }
  }

  .pdp-hero__thumbs-rail {
    display: flex;
    flex-direction: column;
    gap: 8px;
    overflow-y: auto;
    overflow-x: hidden;
    max-height: 100%;
    height: 100%;
    padding: 4px 2px;
    scrollbar-width: thin;
  }
  @media (max-width: 1024px) {
    .pdp-hero__thumbs-rail {
      flex-direction: row;
      overflow-x: auto;
      overflow-y: hidden;
      max-height: none;
      height: auto;
      padding: 4px 0;
    }
  }

  .pdp-hero__thumb {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    aspect-ratio: 1 / 1;
    padding: 0;
    border: 2px solid var(--c-border);
    border-radius: var(--r);
    overflow: hidden;
    cursor: pointer;
    background: var(--c-surface);
    opacity: 0.65;
    transition: opacity var(--ease), border-color var(--ease);
    box-sizing: border-box;
  }
  .pdp-hero__thumb.is-active,
  .pdp-hero__thumb:hover {
    opacity: 1;
    border-color: var(--c-accent);
  }
  .pdp-hero__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pdp-hero__stage {
    flex: 1;
    position: relative;
    min-width: 0;
    min-height: 0;
    height: 100%;
    background: var(--c-surface);
    border-radius: var(--r-md);
    overflow: hidden;
    container-type: size;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pdp-hero__main {
    flex: 1;
    min-width: 0;
    min-height: 0;
    height: 100%;
    max-height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    box-sizing: border-box;
  }

  .pdp-hero__main-carousel {
    position: relative;
    flex-shrink: 0;
    min-height: 0;
    min-width: 0;
    aspect-ratio: 1 / 1;
    max-width: 100%;
    max-height: 100%;
    width: min(100cqmin, 100%);
    height: min(100cqmin, 100%);
  }
  @supports not (width: 1cqmin) {
    .pdp-hero__main-carousel {
      width: min(100%, 72vh);
      height: min(100%, 72vh);
    }
  }
  .pdp-main-discount {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.04em;
    background: #16a34a;
    color: #fff;
    padding: 4px 10px;
    border-radius: var(--r);
    pointer-events: none;
  }

  .pdp-hero__main-img-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--c-bg);
    border: none;
    margin: 0;
    padding: 0;
    cursor: zoom-in;
    font: inherit;
    color: inherit;
    text-align: inherit;
  }
  .pdp-hero__main-img-wrap:focus-visible {
    outline: 2px solid var(--c-accent);
    outline-offset: 2px;
  }
  .pdp-hero__main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 1;
    transition: opacity 0.32s ease;
  }

  .pdp-hero__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--c-border);
    background: rgba(0, 0, 0, 0.55);
    color: var(--c-text);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--ease);
  }
  .pdp-hero__nav:hover {
    background: rgba(0, 0, 0, 0.75);
  }
  .pdp-hero__nav--prev {
    left: 12px;
  }
  .pdp-hero__nav--next {
    right: 12px;
  }

  .pdp-hero__buy-col {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: stretch;
    padding-top: 8px;
    min-width: 0;
    max-width: 100%;
    width: 100%;
    min-height: 0;
    height: 100%;
    box-sizing: border-box;
  }
  /*
   * NUNCA `align-items: center` aqui no mobile: em column flex o eixo cruzado é a largura
   * e o filho passa a medir pelo min-content do card (fila de tamanhos) → overflow horizontal.
   */
  @media (max-width: 1024px) {
    .pdp-hero__buy-col {
      align-items: stretch;
      width: 100%;
      max-width: 100%;
    }
  }

  .pdp-hero__sidebar-stack {
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
    max-width: min(500px, 100%);
    align-self: stretch;
    flex: 1 1 auto;
    min-height: 0;
    max-height: 100%;
    overflow-y: auto;
    padding-right: 4px;
    scrollbar-width: thin;
  }
  @media (max-width: 1024px) {
    .pdp-hero__sidebar-stack {
      max-height: none;
      overflow-y: visible;
      max-width: 100%;
      min-width: 0;
    }
  }

  .pdp-buy-card {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    padding: clamp(16px, 3vw, 22px) clamp(12px, 4vw, 22px) 20px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-shrink: 0;
    overflow-wrap: break-word;
    overflow-x: hidden;
  }

  .pdp-characteristics {
    width: 100%;
    padding: 16px 18px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex-shrink: 0;
  }
  .pdp-characteristics .pdp-details {
    margin: 0;
  }

  .pdp-stock-notify {
    margin-top: 12px;
    padding: 12px 14px;
    border-radius: var(--r, 8px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(0, 0, 0, 0.25);
  }
  .pdp-stock-notify__intro {
    font-size: 13px;
    color: var(--c-muted);
    line-height: 1.45;
    margin: 0 0 10px;
  }
  .pdp-stock-notify__row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }
  .pdp-stock-notify__input {
    flex: 1 1 180px;
    min-width: 0;
    min-height: 40px;
    padding: 0 12px;
    border-radius: var(--r, 8px);
    border: 1px solid #2a2a2a;
    background: #0d0d0d;
    color: var(--c-text);
    font-size: 14px;
  }
  .pdp-stock-notify__btn {
    flex-shrink: 0;
    padding: 0 16px;
    min-height: 40px;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .pdp-stock-notify__feedback {
    margin: 10px 0 0;
    font-size: 12px;
    color: var(--c-muted);
  }
  .pdp-stock-notify__feedback.is-ok {
    color: #4ade80;
  }
  .pdp-stock-notify__feedback.is-err {
    color: #f87171;
  }
  .pdp-stock {
    font-size: 12px;
    font-weight: 600;
    color: var(--c-muted);
    margin: 0;
    line-height: 1.4;
  }

  .pdp-breadcrumb {
    max-width: 100%;
    min-width: 0;
  }
  .pdp-breadcrumb__list {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--c-muted);
    flex-wrap: wrap;
    min-width: 0;
    max-width: 100%;
  }
  .pdp-breadcrumb__list li[aria-current='page'] {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1 1 8rem;
  }
  .pdp-breadcrumb__list a:hover {
    color: var(--c-text);
  }

  .pdp-badge {
    display: inline-block;
    background: var(--c-accent);
    color: var(--c-black);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: var(--r);
  }

  .pdp-title {
    font-family: var(--font-title);
    font-size: clamp(26px, 3.2vw, 40px);
    text-transform: uppercase;
    line-height: 1;
    margin: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
    max-width: 100%;
  }

  .pdp-variation-heading {
    font-size: 12px;
    line-height: 1.4;
    margin: 0 0 2px;
    color: var(--c-muted);
  }
  .pdp-variation-heading__label {
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-muted);
  }
  .pdp-variation-heading__value {
    color: var(--c-text);
    font-weight: 600;
    overflow-wrap: anywhere;
  }

  .pdp-variants-divider {
    height: 0;
    border: 0;
    border-top: 1px solid var(--c-border);
    margin: 6px 0 8px;
  }

  .pdp-variant-row {
    margin-top: 4px;
  }
  .pdp-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-muted);
    margin-bottom: 6px;
  }
  .pdp-variant-values {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    max-width: 100%;
    min-width: 0;
    justify-content: flex-start;
  }
  .pdp-variant-values--swatch {
    gap: 10px;
  }
  .pdp-variant-btn {
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    background: var(--c-bg);
    color: var(--c-text);
    font-size: 10px;
    font-weight: 600;
    min-height: 28px;
    min-width: 30px;
    padding: 0 8px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    flex: 0 1 auto;
    max-width: 100%;
  }
  @media (max-width: 420px) {
    .pdp-buy-card .pdp-variant-btn {
      padding: 0 9px;
      font-size: 10px;
      min-height: 30px;
    }
    .pdp-buy-card .pdp-variant-values {
      gap: 4px;
    }
  }
  .pdp-variant-btn.is-selected:not(.pdp-variant-btn--swatch) {
    border-color: #0a0a0a;
    background: #0a0a0a;
    color: #fff;
  }
  .pdp-variant-btn--swatch.is-selected {
    border-color: var(--c-accent);
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.35);
  }
  .pdp-variant-btn.is-unavailable {
    opacity: 0.35;
    cursor: not-allowed;
  }
  .pdp-variant-x {
    display: none;
  }
  .pdp-variant-btn.is-unavailable .pdp-variant-x {
    display: flex;
    position: absolute;
    inset: 0;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    font-size: 16px;
  }
  .pdp-variant-btn--swatch {
    width: 28px;
    height: 28px;
    min-width: 28px;
    min-height: 28px;
    padding: 0;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.22);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .pdp-variant-btn--swatch:hover:not(:disabled):not(.is-unavailable) {
    transform: scale(1.06);
  }
  .pdp-variant-btn--swatch-neutral .pdp-variant-swatch-inner {
    background-color: #9ca3af !important;
  }
  .pdp-variant-btn--swatch-light {
    border-color: rgba(0, 0, 0, 0.2);
  }
  .pdp-variant-btn--swatch-light.is-selected {
    border-color: var(--c-accent);
  }
  .pdp-variant-swatch-inner {
    display: block;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    box-sizing: border-box;
    border: 1px solid rgba(0, 0, 0, 0.12);
  }
  .pdp-variant-btn-text--sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .pdp-size-chart-row {
    margin: 8px 0 0;
  }
  .pdp-size-chart-link {
    font-size: 12px;
    font-weight: 600;
    color: var(--c-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .pdp-size-chart-link:hover {
    color: var(--c-text);
  }

  .pdp-measure-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 2px;
  }
  .pdp-pill-btn {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text);
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: 999px;
    padding: 8px 14px;
    cursor: pointer;
    transition: border-color var(--ease), background var(--ease);
  }
  .pdp-pill-btn:hover {
    border-color: var(--c-accent);
    color: var(--c-accent);
  }
  .pdp-pill-btn--ghost {
    background: transparent;
  }

  .pdp-price-qty-row {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    gap: clamp(8px, 2.5vw, 14px);
    margin-top: 8px;
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }
  .pdp-price-block {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px;
    margin: 0;
    flex: 1;
    min-width: 0;
  }
  .pdp-price-striked {
    font-size: 15px;
    text-decoration: line-through;
    color: var(--c-muted);
  }
  .pdp-price-current {
    font-size: clamp(17px, 4.5vw, 22px);
    font-weight: 800;
    color: var(--c-accent);
    overflow-wrap: anywhere;
    line-height: 1.1;
  }

  .pdp-qty-wrap {
    flex: 0 0 auto;
    flex-shrink: 0;
    min-width: 108px;
    max-width: 160px;
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    overflow: hidden;
  }

  .pdp-buy-actions {
    display: flex;
    align-items: stretch;
    gap: 10px;
    margin-top: 4px;
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }
  .pdp-buy-actions .btn {
    min-width: 0;
  }

  /* Variante sem estoque: sem preço, qty, compra, quick add nem CEP (classe aplicada em pdp-client) */
  [data-pdp-root].pdp-root--oos-variant #pdp-price-qty-row,
  [data-pdp-root].pdp-root--oos-variant .pdp-buy-actions,
  [data-pdp-root].pdp-root--oos-variant #pdp-shipping-block {
    display: none !important;
  }
  [data-pdp-root].pdp-root--oos-variant #pdp-main-discount {
    visibility: hidden;
  }
  #pdp-sticky-bar.pdp-sticky-bar--oos .pdp-sticky-bar__head-price,
  #pdp-sticky-bar.pdp-sticky-bar--oos .pdp-sticky-bar__head-actions,
  #pdp-sticky-bar.pdp-sticky-bar--oos .pdp-sticky-bar__ship {
    display: none !important;
  }

  .pdp-buy-now {
    flex: 1 1 0;
    min-width: 0;
    max-width: 100%;
    padding: 14px clamp(8px, 2.5vw, 18px);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    /* .btn global usa white-space: nowrap — força overflow em colunas estreitas */
    white-space: normal;
    line-height: 1.25;
    text-align: center;
    hyphens: auto;
  }
  .pdp-atc-icon {
    flex: 0 0 auto;
    width: 52px;
    max-width: 56px;
    min-width: 48px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--c-surface2);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    color: var(--c-text);
    transition: background var(--ease), border-color var(--ease);
  }
  .pdp-atc-icon:hover:not(:disabled) {
    background: var(--c-accent);
    border-color: var(--c-accent);
    color: var(--c-black);
  }
  .pdp-atc-icon:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }
  .pdp-atc-icon img {
    display: block;
    filter: none;
  }
  .pdp-atc-icon:hover:not(:disabled) img {
    filter: brightness(0);
  }
  .pdp-qty-btn {
    width: 36px;
    height: 40px;
    border: 0;
    background: var(--c-bg);
    color: var(--c-text);
    font-size: 18px;
  }
  .pdp-qty-input {
    flex: 1;
    min-width: 0;
    height: 40px;
    text-align: center;
    border: 0;
    border-left: 1px solid var(--c-border);
    border-right: 1px solid var(--c-border);
    background: #0d0d0d;
    color: var(--c-text);
  }
  .pdp-qty-input::-webkit-outer-spin-button,
  .pdp-qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .pdp-shipping {
    margin-top: 8px;
    padding-top: 12px;
    border-top: 1px solid var(--c-border);
  }
  .pdp-cep-row {
    display: flex;
    gap: 8px;
  }
  .pdp-cep-input {
    width: 100%;
    max-width: 200px;
    padding: 10px 12px;
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    background: var(--c-bg);
    color: var(--c-text);
    font-size: 14px;
  }
  .pdp-cep-hint {
    font-size: 12px;
    color: #f87171;
    margin-top: 6px;
    min-height: 1.2em;
  }
  .pdp-cep-static {
    font-size: 12px;
    color: var(--c-muted);
    margin-top: 8px;
    line-height: 1.5;
  }

  .pdp-details {
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    padding: 0 12px;
    background: var(--c-bg);
  }
  .pdp-details summary {
    cursor: pointer;
    padding: 12px 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .pdp-details__body {
    padding-bottom: 12px;
  }
  .pdp-composition {
    font-size: 13px;
    line-height: 1.65;
    color: var(--c-muted);
  }
  .pdp-tech-dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 16px;
    font-size: 13px;
    padding-bottom: 12px;
  }
  .pdp-tech-dl dt {
    color: var(--c-muted);
    font-weight: 600;
  }
  .pdp-tech-dl dd {
    margin: 0;
    color: var(--c-text);
  }

  .pdp-collection-sub {
    font-weight: 500;
    color: var(--c-muted);
    text-transform: none;
  }

  .pdp-carousel {
    margin-top: 24px;
  }

  .pdp-related {
    min-width: 0;
    max-width: 100%;
    overflow-x: visible;
    overflow-y: visible;
  }
  .pdp-related .container {
    min-width: 0;
    max-width: 100%;
  }

  .pdp-below-fold {
    min-width: 0;
    max-width: 100%;
    padding-bottom: 48px;
  }

  .pdp-accordion-row__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px 48px;
    align-items: start;
  }
  .pdp-accordion-row__grid--split {
    grid-template-columns: 1fr 1fr;
  }
  @media (max-width: 900px) {
    .pdp-accordion-row__grid--split {
      grid-template-columns: 1fr;
    }
  }
  .pdp-accordion-row__col .pdp-faq__list {
    max-width: none;
    width: 100%;
  }
  .pdp-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 80px);
