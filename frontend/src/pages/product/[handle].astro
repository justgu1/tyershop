      grid-template-columns: 1fr;
    }
    .pdp-split--img-left .pdp-split__img {
      order: 0;
    }
  }
  .pdp-split__title {
    font-family: var(--font-title);
    font-size: clamp(28px, 4vw, 48px);
    text-transform: uppercase;
    margin: 8px 0 16px;
  }
  .pdp-split__body {
    font-size: 15px;
    line-height: 1.75;
    color: var(--c-muted);
  }
  .pdp-split__img {
    border-radius: var(--r-md);
    overflow: hidden;
  }
  .pdp-split__img img {
    width: 100%;
    display: block;
  }

  .pdp-fullbleed {
