    border-color: var(--c-accent);
    color: var(--c-black);
  }
  .pdp-atc-icon:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }
  .pdp-atc-icon img {
    display: block;
    filter: none;
  }
  .pdp-atc-icon:hover:not(:disabled) img {
    filter: brightness(0);
  }
  .pdp-qty-btn {
    width: 36px;
    height: 40px;
    border: 0;
    background: var(--c-bg);
    color: var(--c-text);
    font-size: 18px;
  }
  .pdp-qty-input {
    flex: 1;
    min-width: 0;
    height: 40px;
    text-align: center;
    border: 0;
    border-left: 1px solid var(--c-border);
    border-right: 1px solid var(--c-border);
    background: #0d0d0d;
    color: var(--c-text);
  }
  .pdp-qty-input::-webkit-outer-spin-button,
  .pdp-qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .pdp-shipping {
    margin-top: 8px;
    padding-top: 12px;
    border-top: 1px solid var(--c-border);
  }
  .pdp-cep-row {
    display: flex;
    gap: 8px;
  }
  .pdp-cep-input {
    width: 100%;
    max-width: 200px;
    padding: 10px 12px;
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    background: var(--c-bg);
    color: var(--c-text);
    font-size: 14px;
  }
  .pdp-cep-hint {
    font-size: 12px;
    color: #f87171;
    margin-top: 6px;
    min-height: 1.2em;
  }
  .pdp-cep-static {
    font-size: 12px;
    color: var(--c-muted);
    margin-top: 8px;
    line-height: 1.5;
  }

  .pdp-details {
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    padding: 0 12px;
    background: var(--c-bg);
  }
  .pdp-details summary {
    cursor: pointer;
    padding: 12px 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .pdp-details__body {
    padding-bottom: 12px;
  }
  .pdp-composition {
    font-size: 13px;
    line-height: 1.65;
    color: var(--c-muted);
  }
  .pdp-tech-dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 16px;
    font-size: 13px;
    padding-bottom: 12px;
  }
  .pdp-tech-dl dt {
    color: var(--c-muted);
    font-weight: 600;
  }
  .pdp-tech-dl dd {
    margin: 0;
    color: var(--c-text);
  }

  .pdp-collection-sub {
    font-weight: 500;
    color: var(--c-muted);
    text-transform: none;
  }

  .pdp-carousel {
    margin-top: 24px;
  }

  .pdp-below-fold {
    padding-bottom: 48px;
  }

  .pdp-accordion-row__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px 48px;
    align-items: start;
  }
  .pdp-accordion-row__grid--split {
    grid-template-columns: 1fr 1fr;
  }
  @media (max-width: 900px) {
    .pdp-accordion-row__grid--split {
      grid-template-columns: 1fr;
    }
  }
  .pdp-accordion-row__col .pdp-faq__list {
    max-width: none;
    width: 100%;
  }
  .pdp-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
    padding-block: clamp(48px, 8vw, 96px);
  }
  .pdp-split--img-left .pdp-split__img {
    order: -1;
  }
  @media (max-width: 768px) {
    .pdp-split {
      grid-template-columns: 1fr;
    }
    .pdp-split--img-left .pdp-split__img {
      order: 0;
    }
  }
  .pdp-split__title {
    font-family: var(--font-title);
    font-size: clamp(28px, 4vw, 48px);
    text-transform: uppercase;
    margin: 8px 0 16px;
