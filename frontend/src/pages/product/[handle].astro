---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getLangFromUrl, t, getPathForLang } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { getMedusaStoreUrl } from '../../lib/medusa-env';
import { getProductListQueryString, getVariantPriceInfo, resolveDefaultRegionId } from '../../lib/medusa-pricing';
import { getVariantSlideUrls } from '../../lib/product-variant-gallery';
import { formatVariationValuesOnly, getProductVariantData } from '../../lib/product-variants';
import { cssColorForOptionValue, isColorOptionRow } from '../../lib/variant-color-swatches';
import {
  compositionText,
  metaString,
  parseFaqItems,
  parseProductDetailBlocks,
  parseTechSheetRows,
} from '../../lib/product-pdp-metadata';

/** PDP dinâmica: qualquer `handle` válido na Medusa (não depende só do pré-render). */
export const prerender = false;

const lang: Lang = getLangFromUrl(Astro.url);

const { handle } = Astro.params;
const pk = 'pk_56a7e1a252f159acbc6c590a025dac7a69d4c869fd621f0273ad10c2a87e3975';
const medusaHeaders = { 'x-publishable-api-key': pk };
let product: any = null;
let related: any[] = [];
let newest: any[] = [];

try {
  const url = getMedusaStoreUrl();
  const regionId = await resolveDefaultRegionId(url, medusaHeaders);
  const q = getProductListQueryString(regionId);
  const res = await fetch(
    `${url}/store/products?${q}&handle=${encodeURIComponent(handle ?? '')}&limit=1`,
    { headers: medusaHeaders, signal: AbortSignal.timeout(5000) }
  );
  if (res.ok) {
    const { products } = await res.json();
    product = products?.[0] ?? null;
    if (product?.collection?.id) {
      const rRes = await fetch(
        `${url}/store/products?${q}&collection_id[]=${product.collection.id}&limit=12`,
        { headers: medusaHeaders, signal: AbortSignal.timeout(5000) }
      );
      if (rRes.ok) {
        const { products: rp } = await rRes.json();
        related = (rp ?? []).filter((p: any) => p.handle !== handle).slice(0, 8);
      }
    }
    const newestRes = await fetch(`${url}/store/products?${q}&limit=16`, {
      headers: medusaHeaders,
      signal: AbortSignal.timeout(5000),
    });
    if (newestRes.ok) {
      const { products: np } = await newestRes.json();
      newest = [...(np ?? [])]
        .filter((p: any) => p?.handle && p.handle !== handle)
        .sort(
          (a: any, b: any) =>
            new Date(b?.created_at || 0).getTime() - new Date(a?.created_at || 0).getTime()
        )
        .slice(0, 8);
    }
  }
} catch {}

const productFound = !!product;
if (!productFound) {
  Astro.response.status = 404;
}

const md = (productFound ? (product!.metadata ?? {}) : {}) as Record<string, unknown>;
const dropHandleRaw = productFound
  ? String(product!.metadata?.drop ?? '').trim() || String(product!.collection?.handle ?? '').trim()
  : '';
const dropHandle = dropHandleRaw.toLowerCase().replace(/[^a-z0-9-_]/g, '');
const customDropModules = import.meta.glob('../../components/drops/**/*.astro', { eager: true }) as Record<
  string,
  { default?: any }
>;
const productSpecificKey = `../../components/drops/products/${String(handle ?? '').toLowerCase()}.astro`;
const dropProductKey = dropHandle
  ? `../../components/drops/${dropHandle}/${String(handle ?? '').toLowerCase()}.astro`
  : '';
const dropPageKey = dropHandle ? `../../components/drops/${dropHandle}.astro` : '';
const CustomDropComponent =
  customDropModules[productSpecificKey]?.default ||
  (dropProductKey ? customDropModules[dropProductKey]?.default : null) ||
  (dropPageKey ? customDropModules[dropPageKey]?.default : null) ||
  null;

const {
  stockReliable,
  normalizedVariants: normalizedVariantsRaw,
  optionRows,
  defaultVariant,
  defaultVariantTitle,
} = productFound
  ? getProductVariantData(product!)
  : {
      stockReliable: false,
      normalizedVariants: [],
      optionRows: [],
      defaultVariant: null,
      defaultVariantTitle: '',
    };

const variantById = productFound
  ? new Map<string, any>((product!.variants ?? []).map((v: any) => [String(v.id ?? ''), v]))
  : new Map<string, any>();

const defaultPriceInfo = productFound ? getVariantPriceInfo(defaultVariant) : null;
const defaultNorm =
  normalizedVariantsRaw.find((n) => n.id === defaultVariant?.id) ?? normalizedVariantsRaw[0];
const initialSlides = productFound
  ? getVariantSlideUrls(defaultVariant, product!)
  : ['/logo.webp'];
const defaultMaxQty = defaultNorm?.maxQty;
const defaultMaxQtyAttr =
  defaultMaxQty != null && Number.isFinite(Number(defaultMaxQty)) ? String(Math.max(0, Math.floor(Number(defaultMaxQty)))) : '';
const defaultDiscountPct = defaultNorm?.discountPercent ?? 0;
const variationValuesLine = formatVariationValuesOnly(defaultVariant, optionRows);
const pdpVariantsPayload = normalizedVariantsRaw.map((v) => ({
  id: v.id,
  title: v.title,
  price: v.price,
  soldOut: v.soldOut,
  maxQty: v.maxQty,
  options: v.options,
  images: v.images,
  slideUrls: v.slideUrls,
  priceDisplay: v.priceDisplay,
  originalDisplay: v.originalDisplay,
  discountPercent: v.discountPercent,
  allowBackorder: variantById.get(v.id)?.allow_backorder === true,
}));

const stockMsgs = {
  out: t(lang, 'pdp', 'stock_out'),
  backorder: t(lang, 'pdp', 'stock_backorder'),
  unverified: t(lang, 'pdp', 'stock_unverified'),
  available: t(lang, 'pdp', 'stock_available'),
  units: t(lang, 'pdp', 'stock_units'),
};

function initialStockLine(): string {
  if (!productFound || !defaultNorm) return '';
  if (defaultNorm.soldOut) return stockMsgs.out;
  const raw = variantById.get(defaultNorm.id);
  if (raw?.allow_backorder === true) return stockMsgs.backorder;
  if (!stockReliable) return stockMsgs.unverified;
  if (defaultNorm.maxQty != null && defaultNorm.maxQty > 0) {
    return stockMsgs.units.replace('{count}', String(defaultNorm.maxQty));
  }
  return stockMsgs.available;
}

const galleryImages = productFound
  ? product!.images ?? (product!.thumbnail ? [{ url: product!.thumbnail }] : [])
  : [];
const sizeGuideUrl = metaString(md, 'size_guide_image_url');
const modelSizeUrl = metaString(md, 'model_size_image_url');
const composition = compositionText(md);
const techRows = parseTechSheetRows(md);
const faqItemsRaw = parseFaqItems(md);
const faqItems =
  faqItemsRaw.length > 0
    ? faqItemsRaw
    : [
        { q: t(lang, 'pdp', 'faq_default_q1'), a: t(lang, 'pdp', 'faq_default_a1') },
        { q: t(lang, 'pdp', 'faq_default_q2'), a: t(lang, 'pdp', 'faq_default_a2') },
      ];

const productDetailBlocksRaw = parseProductDetailBlocks(md);
const productDescriptionPlain =
  productFound && typeof product!.description === 'string' ? product!.description.trim() : '';
let productDetailBlocks = productDetailBlocksRaw;
if (productDetailBlocks.length === 0 && productDescriptionPlain) {
  productDetailBlocks = [{ title: t(lang, 'pdp', 'about_product_fallback'), body: productDescriptionPlain }];
}

const sizeGuideOpensNewTab = sizeGuideUrl ? /^https?:\/\//i.test(sizeGuideUrl) : false;

const imgUrl = (i: number) => galleryImages[i]?.url ?? null;
const storyA = productFound
  ? metaString(md, 'pdp_story_a') ?? product!.description ?? t(lang, 'product', 'inspiration_text')
  : '';
const storyB = productFound
  ? metaString(md, 'pdp_story_b') ?? product!.description ?? t(lang, 'product', 'feature_1')
  : '';

const jsonLd = productFound
  ? {
      '@context': 'https://schema.org',
      '@type': 'Product',
      name: product!.title,
      description: product!.description,
      image: galleryImages.map((i: any) => `https://tyer.com.br${i.url}`),
      brand: { '@type': 'Brand', name: 'Tyer' },
      ...(defaultPriceInfo && {
        offers: {
          '@type': 'Offer',
          price: defaultPriceInfo.amountCents / 100,
          priceCurrency: defaultPriceInfo.currency,
          availability: 'https://schema.org/InStock',
        },
      }),
    }
  : null;
---

<Layout
  title={productFound ? product!.title : 'Produto não encontrado'}
  description={productFound ? (product!.description ?? 'Limited edition streetwear piece by Tyer.') : 'Esta página não existe ou o produto foi removido.'}
  lang={lang}
  ogImage={productFound ? (product!.thumbnail ?? '/logo.webp') : '/logo.webp'}
  ogType="product"
  jsonLd={jsonLd ?? undefined}
  noindex={!productFound}
>
  {productFound ? (
    <>
  <section
    class="pdp-hero"
    data-pdp-root
    data-stock-reliable={stockReliable ? 'true' : 'false'}
    data-stock-msgs={JSON.stringify(stockMsgs)}
    data-variants={encodeURIComponent(JSON.stringify(pdpVariantsPayload))}
    data-option-rows={encodeURIComponent(JSON.stringify(optionRows))}
    aria-labelledby="pdp-title"
  >
    <div class="pdp-hero__media">
      <div class="pdp-hero__media-carousel-block">
        <div class="pdp-hero__thumbs-rail-wrap">
          <div class="pdp-hero__thumbs-rail" id="pdp-thumbs-rail" role="tablist" aria-label={t(lang, 'pdp', 'gallery_thumbs')}>
            {initialSlides.map((url: string, i: number) => (
              <button
                type="button"
                class:list={['pdp-hero__thumb', { 'is-active': i === 0 }]}
                data-slide-idx={i}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-label={`${t(lang, 'pdp', 'slide')} ${i + 1}`}
              >
                <img src={url} alt="" width="64" height="80" loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
              </button>
            ))}
          </div>
        </div>
        <div class="pdp-hero__stage">
          <button type="button" class="pdp-hero__nav pdp-hero__nav--prev" id="pdp-carousel-prev" aria-label={t(lang, 'pdp', 'prev_slide')}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <div class="pdp-hero__main">
            <div class="pdp-hero__main-carousel" id="pdp-main-carousel">
              <span
                class="pdp-main-discount"
                id="pdp-main-discount"
                hidden={defaultDiscountPct <= 0}
              >
                {defaultDiscountPct > 0 ? `−${defaultDiscountPct}%` : ''}
              </span>
              <button
                type="button"
                class="pdp-hero__main-img-wrap"
                id="pdp-main-img-wrap"
                aria-label={t(lang, 'pdp', 'gallery_fullscreen')}
              >
                <img
                  id="pdp-main-img"
                  src={initialSlides[0] ?? '/logo.webp'}
                  alt={product.title}
                  class="pdp-hero__main-img"
                  width="900"
                  height="1125"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              </button>
            </div>
          </div>
          <button type="button" class="pdp-hero__nav pdp-hero__nav--next" id="pdp-carousel-next" aria-label={t(lang, 'pdp', 'next_slide')}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>

      {related.length > 0 && (
        <section class="pdp-hero__drop-rail section" aria-labelledby="pdp-drop-rail-title">
          <div class="pdp-hero__drop-rail-inner">
            <h2 class="pdp-hero__drop-rail-title" id="pdp-drop-rail-title">
              {t(lang, 'pdp', 'drop_section_title')}
              {product.collection?.title && (
                <span class="pdp-hero__drop-rail-sub"> — {product.collection.title}</span>
              )}
            </h2>
            <div class="pdp-product-rail pdp-hero__drop-carousel" role="list">
              {related.map((p) => (
                <ProductCard product={p} lang={lang} role="listitem" />
              ))}
            </div>
          </div>
        </section>
      )}
    </div>

    <div class="pdp-hero__buy-col">
      <div class="pdp-hero__sidebar-stack">
      <div class="pdp-buy-card" data-pdp-buy-card>
        <nav class="pdp-breadcrumb" aria-label="Breadcrumb">
          <ol class="pdp-breadcrumb__list">
            <li><a href={getPathForLang('/', lang)}>Tyer</a></li>
            <li aria-hidden="true">/</li>
            {product.collection?.handle ? (
              <>
                <li>
                  <a href={getPathForLang(`/collections/${product.collection.handle}`, lang)}>
                    {product.collection.title ?? product.collection.handle}
                  </a>
                </li>
                <li aria-hidden="true">/</li>
                <li aria-current="page">{product.title}</li>
              </>
            ) : (
              <>
                <li>
                  <a href={getPathForLang('/shop', lang)}>{t(lang, 'nav', 'shop')}</a>
                </li>
                <li aria-hidden="true">/</li>
                <li aria-current="page">{product.title}</li>
              </>
            )}
          </ol>
        </nav>

        {product.metadata?.badge && <span class="pdp-badge">{String(product.metadata.badge)}</span>}
        <h1 class="pdp-title" id="pdp-title">{product.title}</h1>

        {optionRows.length > 0 && (
          <>
            <p class="pdp-variation-heading" id="pdp-variation-heading">
              <span class="pdp-variation-heading__label">{t(lang, 'pdp', 'variation_label')}</span>{' '}
              <span class="pdp-variation-heading__value" id="pdp-variation-value">
                {variationValuesLine || defaultVariantTitle}
              </span>
            </p>
            <div class="pdp-variants" role="group" aria-label={t(lang, 'product', 'select_size')}>
              {optionRows.map((row: { id: string; title: string; values: string[] }) => {
                const colorRow = isColorOptionRow(row.title);
                return (
                  <div class="pdp-variant-row">
                    <p class="pdp-label">{row.title}</p>
                    <div class="pdp-variant-values" role="radiogroup" aria-label={row.title}>
                      {row.values.map((val: string) => {
                        const sel = (defaultVariant?.options ?? []).find(
                          (o: any) => String(o.option_id ?? o.id) === row.id
                        );
                        const isSel = String(sel?.value ?? '') === val;
                        const swatchHex = colorRow ? cssColorForOptionValue(val) : null;
                        return (
                          <button
                            type="button"
                            class:list={[
                              'pdp-variant-btn',
                              { 'is-selected': isSel, 'is-unavailable': false, 'pdp-variant-btn--color': colorRow },
                            ]}
                            data-option-id={row.id}
                            data-option-value={val}
                            aria-checked={isSel ? 'true' : 'false'}
                          >
                            {swatchHex && (
                              <span
                                class="pdp-variant-swatch"
                                style={`background-color: ${swatchHex}`}
                                aria-hidden="true"
                              />
                            )}
                            <span class="pdp-variant-btn-text">{val}</span>
                            <span class="pdp-variant-x" aria-hidden="true">×</span>
                          </button>
                        );
                      })}
                    </div>
                  </div>
                );
              })}
            </div>
            {sizeGuideUrl && (
              <p class="pdp-size-chart-row">
                <a
                  href={sizeGuideUrl}
                  class="pdp-size-chart-link"
                  target={sizeGuideOpensNewTab ? '_blank' : undefined}
                  rel={sizeGuideOpensNewTab ? 'noopener noreferrer' : undefined}
                >
                  {t(lang, 'pdp', 'size_chart')}
                </a>
              </p>
            )}
          </>
        )}

        <div class="pdp-measure-btns">
          {modelSizeUrl && (
            <button type="button" class="pdp-pill-btn pdp-pill-btn--ghost" id="pdp-open-model" data-modal-target="pdp-modal-model">
              {t(lang, 'pdp', 'model_measures')}
            </button>
          )}
        </div>

        <div class="pdp-price-qty-row">
          <div class="pdp-price-block" id="pdp-price-block">
            <span
              class="pdp-price-striked"
              id="pdp-price-original"
              hidden={!defaultPriceInfo?.originalDisplay}
            >
              {defaultPriceInfo?.originalDisplay ?? ''}
            </span>
            <span class="pdp-price-current" id="pdp-price-current">{defaultPriceInfo?.display ?? ''}</span>
          </div>
          <div class="pdp-qty-wrap" role="group" aria-label={t(lang, 'pdp', 'qty_label')}>
            <button type="button" class="pdp-qty-btn" id="pdp-qty-dec" aria-label={t(lang, 'pdp', 'qty_dec')}>−</button>
            <input
              id="pdp-qty-input"
              class="pdp-qty-input"
              type="number"
              min="1"
              step="1"
              value="1"
              inputmode="numeric"
              pattern="[0-9]*"
              aria-label={t(lang, 'pdp', 'qty_label')}
            />
            <button type="button" class="pdp-qty-btn" id="pdp-qty-inc" aria-label={t(lang, 'pdp', 'qty_inc')}>+</button>
          </div>
        </div>

        <p class="pdp-stock" id="pdp-stock-line" role="status">{initialStockLine()}</p>

        <div class="pdp-buy-actions">
          <button type="button" class="btn btn-primary pdp-buy-now" id="pdp-buy-now">
            {t(lang, 'pdp', 'buy_now')}
          </button>
          <button
            type="button"
            class="btn pdp-atc-icon"
            id="pdp-atc"
            data-variant-id={defaultVariant?.id}
            data-title={product.title}
            data-price={defaultPriceInfo?.amountCents ?? ''}
            data-thumbnail={initialSlides[0] ?? product.thumbnail ?? ''}
            data-variant-title={defaultVariantTitle}
            data-max-qty={defaultMaxQtyAttr}
            data-qty="1"
            aria-label={t(lang, 'product', 'add_to_cart')}
          >
            <img src="/icons/quick-cart.svg" alt="" width="22" height="22" />
          </button>
        </div>

        <div class="pdp-shipping">
          <label class="pdp-label" for="pdp-cep-input">{t(lang, 'pdp', 'shipping_cep')}</label>
          <div class="pdp-cep-row">
            <input
              id="pdp-cep-input"
              class="pdp-cep-input"
              type="text"
              inputmode="numeric"
              autocomplete="postal-code"
              maxlength="9"
              placeholder="00000-000"
              aria-describedby="pdp-cep-hint"
            />
          </div>
          <p id="pdp-cep-hint" class="pdp-cep-hint" role="status"></p>
          <p class="pdp-cep-static">{t(lang, 'pdp', 'shipping_estimate_placeholder')}</p>
        </div>
      </div>

        {(composition || techRows.length > 0) && (
          <div class="pdp-characteristics">
            {composition && (
              <details class="pdp-details">
                <summary>{t(lang, 'pdp', 'differentials')}</summary>
                <div class="pdp-details__body">
                  <p class="pdp-composition">{composition}</p>
                </div>
              </details>
            )}

            {techRows.length > 0 && (
              <details class="pdp-details">
                <summary>{t(lang, 'pdp', 'tech_sheet')}</summary>
                <dl class="pdp-tech-dl">
                  {techRows.map((row) => (
                    <>
                      <dt>{row.label}</dt>
                      <dd>{row.value}</dd>
                    </>
                  ))}
                </dl>
              </details>
            )}
          </div>
        )}
      </div>
    </div>
  </section>

  <div class="pdp-below-fold">
    {(productDetailBlocks.length > 0 || faqItems.length > 0) && (
      <section
        class="pdp-accordion-row section container"
        aria-label={`${t(lang, 'pdp', 'product_details_title')} · ${t(lang, 'pdp', 'faq_title')}`}
      >
        <div
          class:list={[
            'pdp-accordion-row__grid',
            { 'pdp-accordion-row__grid--split': productDetailBlocks.length > 0 && faqItems.length > 0 },
          ]}
        >
          {productDetailBlocks.length > 0 && (
            <div class="pdp-accordion-row__col">
              <h2 class="section__title" id="pdp-product-details-title">{t(lang, 'pdp', 'product_details_title')}</h2>
              <div class="pdp-faq__list">
                {productDetailBlocks.map((b) => (
                  <details class="pdp-faq__item">
                    <summary>{b.title}</summary>
                    <p class="pdp-faq__a">{b.body}</p>
                  </details>
                ))}
              </div>
            </div>
          )}
          {faqItems.length > 0 && (
            <div class="pdp-accordion-row__col">
              <h2 class="section__title" id="pdp-faq-title">{t(lang, 'pdp', 'faq_title')}</h2>
              <div class="pdp-faq__list">
                {faqItems.map((item) => (
                  <details class="pdp-faq__item">
                    <summary>{item.q}</summary>
                    <p class="pdp-faq__a">{item.a}</p>
                  </details>
                ))}
              </div>
            </div>
          )}
        </div>
      </section>
    )}

    {imgUrl(1) && (
      <section class="pdp-split pdp-split--text-left container">
        <div class="pdp-split__text">
          <p class="section-label">01 — {t(lang, 'product', 'inspiration')}</p>
          <h2 class="pdp-split__title">{t(lang, 'product', 'inspiration')}</h2>
          <p class="pdp-split__body">{storyA}</p>
        </div>
        <div class="pdp-split__img">
          <img src={imgUrl(1)!} alt="" width="640" height="800" loading="lazy" decoding="async" />
        </div>
      </section>
    )}

    {imgUrl(2) && (
      <section class="pdp-split pdp-split--img-left container">
        <div class="pdp-split__img">
          <img src={imgUrl(2)!} alt="" width="640" height="800" loading="lazy" decoding="async" />
        </div>
        <div class="pdp-split__text">
          <p class="section-label">02 — {t(lang, 'product', 'features')}</p>
          <h2 class="pdp-split__title">{t(lang, 'product', 'features')}</h2>
          <p class="pdp-split__body">{storyB}</p>
        </div>
      </section>
    )}

    {imgUrl(3) && (
      <section class="pdp-fullbleed" aria-hidden="false">
        <img src={imgUrl(3)!} alt="" class="pdp-fullbleed__img" width="1440" height="720" loading="lazy" decoding="async" />
        <div class="pdp-fullbleed__cap container">
          <h2 class="pdp-fullbleed__title">03 — {t(lang, 'product', 'street')}</h2>
        </div>
      </section>
    )}

  </div>

  {CustomDropComponent && (
    <CustomDropComponent product={product!} lang={lang} related={related} newest={newest} />
  )}

  {newest.length > 0 && (
    <section class="pdp-related section" aria-labelledby="newest-title">
      <div class="container">
        <h2 class="section__title" id="newest-title">{t(lang, 'shop', 'section_novos')}</h2>
        <div class="pdp-product-rail pdp-carousel" id="pdp-newest-carousel" role="list">
          {newest.map((p) => (
            <ProductCard product={p} lang={lang} role="listitem" />
          ))}
        </div>
      </div>
    </section>
  )}

  {sizeGuideUrl && (
    <dialog class="pdp-dialog" id="pdp-modal-size-guide" aria-label={t(lang, 'pdp', 'size_guide')}>
      <button type="button" class="pdp-dialog__close" data-close-modal>&times;</button>
      <img src={sizeGuideUrl} alt="" class="pdp-dialog__img" />
    </dialog>
  )}
  {modelSizeUrl && (
    <dialog class="pdp-dialog" id="pdp-modal-model" aria-label={t(lang, 'pdp', 'model_measures')}>
      <button type="button" class="pdp-dialog__close" data-close-modal>&times;</button>
      <img src={modelSizeUrl} alt="" class="pdp-dialog__img" />
    </dialog>
  )}
    <dialog class="pdp-lightbox" id="pdp-lightbox" aria-modal="true" aria-label={t(lang, 'pdp', 'gallery_fullscreen')}>
      <button
        type="button"
        class="pdp-lightbox__backdrop"
        data-close-modal
        tabindex="-1"
        aria-label={t(lang, 'pdp', 'lightbox_close')}
      />
      <button type="button" class="pdp-lightbox__close" data-close-modal aria-label={t(lang, 'pdp', 'lightbox_close')}>
        &times;
      </button>
      <div class="pdp-lightbox__row">
        <button
          type="button"
          class="pdp-lightbox__nav pdp-lightbox__nav--prev"
          id="pdp-lightbox-prev"
          aria-label={t(lang, 'pdp', 'lightbox_prev')}
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            ><path d="m15 18-6-6 6-6" /></svg
          >
        </button>
        <div class="pdp-lightbox__inner">
          <img id="pdp-lightbox-img" src="" alt="" class="pdp-lightbox__img" width="1200" height="1500" />
          <p class="pdp-lightbox__counter" id="pdp-lightbox-counter" aria-live="polite"></p>
        </div>
        <button
          type="button"
          class="pdp-lightbox__nav pdp-lightbox__nav--next"
          id="pdp-lightbox-next"
          aria-label={t(lang, 'pdp', 'lightbox_next')}
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            ><path d="m9 18 6-6-6-6" /></svg
          >
        </button>
      </div>
    </dialog>
    </>
  ) : (
    <section class="nf">
      <p class="nf__code">404</p>
      <h1 class="nf__title">{t(lang, 'pdp', 'product_not_found_title')}</h1>
      <p class="nf__sub">{t(lang, 'pdp', 'product_not_found_sub')}</p>
      <div class="nf__actions">
        <a href={getPathForLang('/', lang)} class="btn btn-primary">{t(lang, 'pdp', 'product_not_found_home')}</a>
        <a href={getPathForLang('/shop', lang)} class="btn btn-outline">{t(lang, 'pdp', 'product_not_found_shop')}</a>
      </div>
    </section>
  )}
</Layout>

<style>
  .pdp-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(16px, 3vw, 40px);
    align-items: start;
    min-height: 75vh;
    min-height: 75svh;
    padding: 24px clamp(16px, 3vw, 40px) 40px;
    max-width: 1600px;
    margin-inline: auto;
  }
  @media (max-width: 1024px) {
    .pdp-hero {
      grid-template-columns: 1fr;
    }
  }

  .pdp-hero__media {
    display: flex;
    flex-direction: column;
    gap: clamp(14px, 2vw, 22px);
    min-height: min(75svh, 820px);
    align-items: stretch;
  }

  .pdp-hero__media-carousel-block {
    display: flex;
    gap: 12px;
    flex: 1;
    min-height: min(70svh, 780px);
    align-items: stretch;
  }
  @media (max-width: 1024px) {
    .pdp-hero__media {
      min-height: 0;
    }
    .pdp-hero__media-carousel-block {
      flex-direction: column-reverse;
      min-height: 0;
    }
  }

  .pdp-hero__drop-rail {
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--c-border);
    padding-top: clamp(12px, 2vw, 20px);
  }
  .pdp-hero__drop-rail-inner {
    width: 100%;
  }
  .pdp-hero__drop-rail-title {
    font-family: var(--font-title);
    font-size: clamp(14px, 1.4vw, 18px);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 12px;
    color: var(--c-text);
  }
  .pdp-hero__drop-rail-sub {
    font-weight: 500;
    color: var(--c-muted);
    text-transform: none;
  }

  /** Trilhos de ProductCard: altura fixa + colunas estreitas (drop + “mais novos”). */
  .pdp-product-rail {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: stretch;
    gap: 10px;
    height: 300px;
    max-height: 300px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    padding-bottom: 6px;
    scrollbar-width: thin;
  }
  .pdp-product-rail > * {
    flex: 0 0 168px;
    width: 168px;
    max-width: 168px;
    min-width: 168px;
    scroll-snap-align: start;
    align-self: stretch;
  }
  .pdp-product-rail :global(.pc) {
    height: 100%;
    max-height: 300px;
  }
  .pdp-product-rail :global(.pc__link) {
    flex-shrink: 0;
  }
  .pdp-product-rail :global(.pc__img-wrap) {
    aspect-ratio: 1;
    max-height: 150px;
    margin-bottom: 8px;
  }
  .pdp-product-rail :global(.pc__img) {
    max-height: 150px;
  }
  .pdp-product-rail :global(.pc__body) {
    flex: 1;
    min-height: 0;
  }
  .pdp-product-rail :global(.pc__name) {
    font-size: 11px;
    min-height: 0;
    -webkit-line-clamp: 2;
  }
  .pdp-product-rail :global(.pc__bottom) {
    margin-top: 6px;
    padding-bottom: 0;
  }
  .pdp-product-rail :global(.pc__price-current) {
    font-size: 13px;
  }
  .pdp-product-rail :global(.pc__price-striked) {
    font-size: 10px;
  }
  .pdp-product-rail :global(.pc__quick-add) {
    width: 30px;
    height: 30px;
  }
  .pdp-product-rail :global(.pc__variants) {
    margin-top: 6px;
    margin-bottom: 4px;
    gap: 4px;
  }
  .pdp-product-rail :global(.pc__variant-btn) {
    height: 24px;
    min-width: 28px;
    font-size: 9px;
    padding: 0 6px;
  }

  .pdp-hero__thumbs-rail-wrap {
    flex: 0 0 72px;
    min-height: 0;
    max-height: min(75svh, 820px);
  }
  @media (max-width: 1024px) {
    .pdp-hero__thumbs-rail-wrap {
      flex: none;
      max-height: 88px;
      width: 100%;
    }
  }

  .pdp-hero__thumbs-rail {
    display: flex;
    flex-direction: column;
    gap: 8px;
    overflow-y: auto;
    overflow-x: hidden;
    max-height: min(75svh, 820px);
    padding: 4px 2px;
    scrollbar-width: thin;
  }
  @media (max-width: 1024px) {
    .pdp-hero__thumbs-rail {
      flex-direction: row;
      overflow-x: auto;
      overflow-y: hidden;
      max-height: none;
      padding: 4px 0;
    }
  }

  .pdp-hero__thumb {
    flex-shrink: 0;
    width: 64px;
    height: 80px;
    padding: 0;
    border: 2px solid var(--c-border);
    border-radius: var(--r);
    overflow: hidden;
    cursor: pointer;
    background: var(--c-surface);
    opacity: 0.65;
    transition: opacity var(--ease), border-color var(--ease);
  }
  .pdp-hero__thumb.is-active,
  .pdp-hero__thumb:hover {
    opacity: 1;
    border-color: var(--c-accent);
  }
  .pdp-hero__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pdp-hero__stage {
    flex: 1;
    position: relative;
    min-width: 0;
    background: var(--c-surface);
    border-radius: var(--r-md);
    overflow: hidden;
  }

  .pdp-hero__main {
    flex: 1;
    min-width: 0;
    height: min(75svh, 820px);
    min-height: 320px;
    display: flex;
    align-items: stretch;
    justify-content: stretch;
  }
  @media (max-width: 1024px) {
    .pdp-hero__main {
      height: min(60svh, 520px);
    }
  }

  .pdp-hero__main-carousel {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 0;
  }
  .pdp-main-discount {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.04em;
    background: #16a34a;
    color: #fff;
    padding: 4px 10px;
    border-radius: var(--r);
    pointer-events: none;
  }

  .pdp-hero__main-img-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--c-bg);
    border: none;
    margin: 0;
    padding: 0;
    cursor: zoom-in;
    font: inherit;
    color: inherit;
    text-align: inherit;
  }
  .pdp-hero__main-img-wrap:focus-visible {
    outline: 2px solid var(--c-accent);
    outline-offset: 2px;
  }
  .pdp-hero__main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 1;
    transition: opacity 0.32s ease;
  }

  .pdp-hero__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--c-border);
    background: rgba(0, 0, 0, 0.55);
    color: var(--c-text);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--ease);
  }
  .pdp-hero__nav:hover {
    background: rgba(0, 0, 0, 0.75);
  }
  .pdp-hero__nav--prev {
    left: 12px;
  }
  .pdp-hero__nav--next {
    right: 12px;
  }

  .pdp-hero__buy-col {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    padding-top: 8px;
    min-width: 0;
  }
  @media (max-width: 1024px) {
    .pdp-hero__buy-col {
      align-items: center;
    }
  }

  .pdp-hero__sidebar-stack {
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
    max-width: 500px;
    max-height: min(calc(100svh - 40px), 920px);
    overflow-y: auto;
    padding-right: 4px;
    scrollbar-width: thin;
  }
  @media (max-width: 1024px) {
    .pdp-hero__sidebar-stack {
      max-height: none;
      overflow-y: visible;
    }
  }

  .pdp-buy-card {
    width: 100%;
    padding: 22px 22px 20px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
