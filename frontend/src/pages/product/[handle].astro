    position: absolute;
    bottom: 24px;
    left: 0;
    right: 0;
  }
  .pdp-fullbleed__title {
    font-family: var(--font-title);
    font-size: clamp(28px, 5vw, 56px);
    text-transform: uppercase;
    color: #fff;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.6);
  }

  .pdp-faq__list {
    max-width: 720px;
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
