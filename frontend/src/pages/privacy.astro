---
import LegalLayout from '../layouts/LegalLayout.astro';
import { getLangFromUrl, t } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const toc = [
  { id: 'data-collection', label: 'Data Collection' },
  { id: 'use', label: 'How We Use Data' },
  { id: 'sharing', label: 'Data Sharing' },
  { id: 'rights', label: 'Your Rights' },
  { id: 'contact', label: 'Contact' },
];
---
<LegalLayout title="Privacy Policy" lang={lang} toc={toc} description="Tyer privacy policy — how we collect and use your data.">
  <p><strong>Last updated:</strong> January 2025</p>

  <h2 id="data-collection">Data Collection</h2>
  <p>We collect information you provide directly: name, email, shipping address, and payment information (processed securely by Mercado Pago — we never store card details).</p>
  <p>We automatically collect: IP address, browser type, pages visited, and purchase history to improve our service.</p>

  <h2 id="use">How We Use Data</h2>
  <ul>
    <li>Process and fulfill your orders</li>
    <li>Send order confirmations and shipping updates</li>
    <li>Send marketing emails (only with your consent)</li>
    <li>Improve our website and products</li>
    <li>Comply with legal obligations</li>
  </ul>

  <h2 id="sharing">Data Sharing</h2>
  <p>We do not sell your personal data. We share data only with service providers necessary to operate our business: payment processors (Mercado Pago), shipping carriers, and analytics services.</p>

  <h2 id="rights">Your Rights</h2>
  <p>Under LGPD (Lei Geral de Proteção de Dados), you have the right to access, correct, delete, or port your personal data. To exercise these rights, contact us at <a href="mailto:privacidade@tyer.com.br">privacidade@tyer.com.br</a>.</p>

  <h2 id="contact">Contact</h2>
  <p>Data Protection Officer: <a href="mailto:dpo@tyer.com.br">dpo@tyer.com.br</a></p>
</LegalLayout>
