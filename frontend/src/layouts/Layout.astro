---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SideCart from '../components/SideCart.astro';
import { getLangFromUrl, hreflangMap, type Lang } from '../i18n/utils';

const medusaInternal =
  import.meta.env.MEDUSA_INTERNAL_URL ||
  import.meta.env.MEDUSA_URL ||
  'http://localhost:9003';
const storePk =
  'pk_56a7e1a252f159acbc6c590a025dac7a69d4c869fd621f0273ad10c2a87e3975';
const storeHeaders = { 'x-publishable-api-key': storePk };
let navDrops: { handle: string; name: string; num: string; img: string }[] = [];
try {
  const cRes = await fetch(`${medusaInternal}/store/collections?limit=50`, {
    headers: storeHeaders,
    signal: AbortSignal.timeout(3000),
  });
  if (cRes.ok) {
    const data = await cRes.json();
    navDrops = (data.collections || []).map((c: { handle: string; title: string }, i: number) => ({
      handle: c.handle,
      name: c.title,
      num: String(i + 1).padStart(2, '0'),
      img: `/collections/${c.handle}.webp`,
    }));
  }
} catch {}
const showCollectionsInNav = navDrops.length > 0;

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'product';
  canonical?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
  bodyClass?: string;
  bare?: boolean;
  lang?: Lang;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const {
  title,
  description = 'Tyer — Exclusive streetwear drops. Pieces with identity, made to last.',
  ogImage = '/logo.webp',
  ogType = 'website',
  canonical = Astro.url.href,
  noindex = false,
  jsonLd,
  bodyClass = '',
  bare = false,
} = Astro.props;

const siteName = 'Tyer';
const fullTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const canonPath = Astro.url.pathname;
const hreflangs = hreflangMap(canonPath);

const schemas: object[] = [
  { '@context': 'https://schema.org', '@type': 'Organization', name: 'Tyer', url: 'https://tyer.com.br', logo: 'https://tyer.com.br/logo.webp' },
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
];
---

<!doctype html>
<html lang={lang === 'pt' ? 'pt-BR' : lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {Object.entries(hreflangs).map(([l, url]) => (
      <link rel="alternate" hreflang={l === 'pt' ? 'pt-BR' : l} href={url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={hreflangs['en']} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/logo-white.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&family=Bebas+Neue&display=swap" rel="stylesheet" />
    {schemas.map(s => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
    <meta name="theme-color" content="#0a0a0a" />
  </head>
  <body class={bodyClass} data-lang={lang}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    {!bare && <Header lang={lang} drops={navDrops} />}
    {!bare && <SideCart lang={lang} />}
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    {!bare && <Footer lang={lang} showCollectionsLink={showCollectionsInNav} />}
  </body>
</html>

<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --c-bg:       #0a0a0a;
  --c-surface:  #111111;
  --c-surface2: #1a1a1a;
  --c-border:   #222222;
  --c-text:     #f0f0f0;
  --c-muted:    #666666;
  --c-accent:   #E77E23;
  --c-accent-d: #c96a10;
  --c-white:    #ffffff;
  --c-black:    #000000;
  --header-h:   72px;
  /* Largura total do viewport: sem teto em telas grandes */
  --max-w:      none;
  --r:          3px;
  --r-md:       6px;
  --ease:       200ms cubic-bezier(0.4, 0, 0.2, 1);
  --font:       'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-title: 'Bebas Neue', 'Impact', sans-serif;
}

html { scroll-behavior: smooth; font-size: 16px; background: var(--c-bg); color: var(--c-text); }
body {
  font-family: var(--font);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
}
main { padding-top: var(--header-h); min-height: 60vh; }
a { color: inherit; text-decoration: none; }
button { cursor: pointer; border: none; background: none; font-family: inherit; font-size: inherit; }
img { max-width: 100%; height: auto; display: block; }
ul, ol { list-style: none; }
input, textarea, select { font-family: inherit; font-size: inherit; }

.skip-link {
  position: absolute; top: -100%; left: 16px; z-index: 9999;
  background: var(--c-accent); color: var(--c-white);
  padding: 8px 16px; border-radius: var(--r); font-size: 14px; font-weight: 600;
}
.skip-link:focus { top: 16px; }

.container { max-width: none; width: 100%; margin-inline: auto; padding-inline: 40px; }
@media (max-width: 768px) { .container { padding-inline: 20px; } }

/** Grelha de produtos (loja, coleções, etc.) — reutilizável em qualquer página. */
.shop-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 20px;
  align-items: start;
}
.shop-grid > * {
  min-width: 0;
}

.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  padding: 12px 28px; border-radius: var(--r);
  font-size: 12px; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  transition: all var(--ease);
  cursor: pointer; border: 1.5px solid transparent;
  font-family: var(--font); white-space: nowrap; line-height: 1;
}
.btn-primary { background: var(--c-accent); color: var(--c-white); border-color: var(--c-accent); }
.btn-primary:hover { background: var(--c-accent-d); border-color: var(--c-accent-d); }
.btn-outline { background: transparent; color: var(--c-text); border-color: #333; }
.btn-outline:hover { background: var(--c-surface2); border-color: #555; }
.btn-sm { padding: 8px 18px; font-size: 11px; }
:focus-visible { outline: 2px solid var(--c-accent); outline-offset: 3px; }

.backdrop {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.75);
  opacity: 0; visibility: hidden;
  transition: opacity var(--ease), visibility var(--ease);
  z-index: 400;
}
.backdrop.is-active { opacity: 1; visibility: visible; }

.section-label {
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--c-accent);
}

/* Acessibilidade: preferências em data-* no <html> (definido pelo painel do rodapé) */
/* Padrão = sem atributo. Quatro passos: md → lg → xl → 2xl */
html[data-tyer-a11y-font="md"] { font-size: 106.25%; }
html[data-tyer-a11y-font="lg"] { font-size: 112.5%; }
html[data-tyer-a11y-font="xl"] { font-size: 125%; }
html[data-tyer-a11y-font="2xl"] { font-size: 131.25%; }
html[data-tyer-a11y-contrast="on"] {
  --c-text: #ffffff;
  --c-muted: #d0d0d0;
  --c-bg: #000000;
  --c-surface: #0a0a0a;
  --c-surface2: #181818;
  --c-border: #555555;
  --c-white: #ffffff;
}
html[data-tyer-a11y-motion="reduce"] *,
html[data-tyer-a11y-motion="reduce"] *::before,
html[data-tyer-a11y-motion="reduce"] *::after {
  animation-duration: 0.001ms !important;
  animation-iteration-count: 1 !important;
  transition-duration: 0.001ms !important;
  scroll-behavior: auto !important;
}
</style>
