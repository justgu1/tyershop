---
import { t, getPathForLang, type Lang } from '../i18n/utils';
interface Props { lang?: Lang; }
const lang: Lang = Astro.props.lang ?? 'pt';
---

<aside
  id="side-cart"
  class="sc"
  role="dialog"
  aria-modal="true"
  aria-label={t(lang, 'cart', 'your_cart')}
  aria-hidden="true"
>
  <div class="sc__header">
    <div class="sc__title-wrap">
      <h2 class="sc__title">{t(lang, 'cart', 'your_cart')} <span id="side-cart-count">(0)</span></h2>
      <button class="sc__clear-link" id="side-cart-clear-all" type="button">Limpar</button>
    </div>
    <button class="sc__close" id="side-cart-close" type="button" aria-label={t(lang, 'cart', 'close')}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div class="sc__body" id="side-cart-body" role="list" aria-live="polite">
    <div class="sc__empty" id="side-cart-empty" hidden>
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      <p>{t(lang, 'cart', 'empty')}</p>
    </div>
  </div>

  <div class="sc__footer" id="side-cart-footer">
    <div class="sc__coupon">
      <input id="side-cart-coupon" class="sc__coupon-input" type="text" placeholder="Cupom de desconto" />
      <button id="side-cart-apply-coupon" class="sc__coupon-btn" type="button">Aplicar cupom</button>
    </div>
    <p class="sc__coupon-feedback" id="side-cart-coupon-feedback" hidden></p>
    <div class="sc__subtotal">
      <span>{t(lang, 'cart', 'subtotal')}</span>
      <strong id="side-cart-subtotal" aria-live="polite">R$ 0,00</strong>
    </div>
    <div class="sc__line-detail">
      <span>Desconto</span>
      <span id="side-cart-discount">R$ 0,00</span>
    </div>
    <div class="sc__line-detail">
      <span>Taxas</span>
      <span id="side-cart-taxes">R$ 0,00</span>
    </div>
    <div class="sc__line-detail">
      <span>Entrega</span>
      <span id="side-cart-shipping">R$ 0,00</span>
    </div>
    <div class="sc__subtotal sc__subtotal--total">
      <span class="sc__total-label">{t(lang, 'cart', 'total')}</span>
      <div class="sc__total-value-wrap">
        <span class="sc__save-tag" id="side-cart-save-tag" hidden>0% OFF</span>
        <strong id="side-cart-total" aria-live="polite">R$ 0,00</strong>
      </div>
    </div>
    <button class="btn btn-primary sc__checkout" id="side-cart-checkout" type="button">
      {t(lang, 'cart', 'checkout')}
    </button>
    <a href={getPathForLang('/cart', lang)} class="sc__view-cart" id="sc-view-cart">
      {t(lang, 'cart', 'view_cart')}
    </a>
  </div>
</aside>

<div class="backdrop" id="side-cart-backdrop" aria-hidden="true" style="z-index:450"></div>

<style>
.sc {
  position: fixed; top: 0; right: 0; bottom: 0;
  width: min(400px, 100vw); z-index: 550;
  background: #111;
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
  display: flex; flex-direction: column;
  border-left: 1px solid #1e1e1e;
  will-change: transform;
}
.sc.is-open { transform: translateX(0); }

.sc__header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 24px; border-bottom: 1px solid #1e1e1e; flex-shrink: 0;
}
.sc__title {
  font-family: var(--font-title); font-size: 22px;
  letter-spacing: 0.06em; text-transform: uppercase;
}
.sc__title-wrap { display: flex; align-items: center; gap: 10px; }
.sc__clear-link { color: var(--c-muted); background: none; border: none; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; cursor: pointer; }
.sc__clear-link:hover { color: #fff; }
.sc__close {
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--r); color: var(--c-muted);
  background: none; border: none; cursor: pointer;
  transition: color var(--ease), background var(--ease);
  flex-shrink: 0;
}
.sc__close:hover { color: var(--c-white); background: rgba(255,255,255,0.08); }

.sc__body {
  flex: 1; overflow-y: auto; padding: 16px 24px;
  display: flex; flex-direction: column; gap: 0;
}
.sc__empty {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 16px; color: var(--c-muted);
  font-size: 14px; text-align: center; padding: 60px 0;
}

/* Itens do carrinho são inseridos via JS: :global = escopo Astro */
.sc :global(.sc-item) {
  position: relative;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 0 0 12px 0;
  margin-bottom: 12px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.18);
}
.sc :global(.sc-item:last-child) { margin-bottom: 0; padding-bottom: 12px; }
.sc :global(.sc-item__head) {
  position: relative;
  padding: 0 40px 8px 0;
  min-height: 28px;
  display: flex;
  align-items: flex-start;
}
.sc :global(.sc-item__name) {
  font-size: 13px;
  font-weight: 500;
  line-height: 1.35;
  color: var(--c-text);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.sc :global(.sc-item__remove) {
  position: absolute;
  top: 0;
  right: 0;
  z-index: 1;
  width: 28px;
  height: 28px;
  padding: 0;
  margin: 0;
  border: 1px solid #3f3f46;
  border-radius: 50%;
  background: #1a1a1a;
  color: #e5e7eb;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: color var(--ease), background var(--ease), border-color var(--ease);
}
.sc :global(.sc-item__remove):hover {
  color: #fff;
  background: #b91c1c;
  border-color: #b91c1c;
}
.sc :global(.sc-item__body) {
  display: grid;
  grid-template-columns: 88px minmax(0, 1fr);
  gap: 10px 12px;
  width: 100%;
  min-width: 0;
  align-items: start;
}
.sc :global(.sc-item__img-wrap) {
  width: 88px;
  height: 88px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a1a1a;
  border-radius: var(--r);
  overflow: hidden;
  border: 1px solid #2a2a2a;
}
.sc :global(.sc-item__img) {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  display: block;
}
.sc :global(.sc-item__right) {
  min-width: 0;
  min-height: 88px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 8px;
  flex: 1;
}
.sc :global(.sc-item__variant) { font-size: 11px; line-height: 1.4; color: var(--c-muted); }
.sc :global(.sc-item__stock) {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase;
  color: #fecaca; background: rgba(127, 29, 29, 0.55);
  border: 1px solid rgba(248, 113, 113, 0.4); border-radius: 999px;
  padding: 3px 8px; margin-bottom: 6px;
}
.sc :global(.sc-item__footer) {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 8px 10px;
  margin-top: auto;
  width: 100%;
  min-width: 0;
}
.sc :global(.sc-item__price) {
  font-size: 13px;
  font-weight: 700;
  color: var(--c-accent);
  white-space: nowrap;
}
/* Stepper: um único bloco com altura uniforme */
.sc :global(.sc-item__stepper) {
  display: inline-flex;
  align-items: stretch;
  height: 32px;
  border: 1px solid #3f3f46;
  border-radius: 8px;
  overflow: hidden;
  background: #0d0d0d;
  flex-shrink: 0;
}
.sc :global(.sc-item__stepper-btn) {
  min-width: 32px;
  width: 32px;
  padding: 0;
  margin: 0;
  border: none;
  background: #1f1f1f;
  color: #f3f4f6;
  font-size: 16px;
  line-height: 1;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background var(--ease);
}
.sc :global(.sc-item__stepper-btn):hover { background: var(--c-accent); color: #fff; }
.sc :global(.sc-item__stepper-btn:disabled),
.sc :global(.sc-item__stepper-input:disabled) { opacity: 0.45; cursor: not-allowed; }
.sc :global(.sc-item__stepper-input) {
  min-width: 36px;
  padding: 0 4px;
  width: 44px;
  border: 0;
  font-size: 13px;
  font-weight: 600;
  color: var(--c-text);
  background: #141414;
  border-left: 1px solid #3f3f46;
  border-right: 1px solid #3f3f46;
  line-height: 32px;
  box-sizing: border-box;
  text-align: center;
  outline: none;
  appearance: textfield;
  -moz-appearance: textfield;
}
.sc :global(.sc-item__stepper-input::-webkit-outer-spin-button),
.sc :global(.sc-item__stepper-input::-webkit-inner-spin-button) {
  -webkit-appearance: none;
  margin: 0;
}

.sc__footer {
  padding: 16px 24px 24px;
  border-top: 1px solid #1e1e1e;
  flex-shrink: 0;
  display: flex; flex-direction: column; gap: 12px;
}
.sc__subtotal {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 14px; color: var(--c-muted);
}
.sc__subtotal strong { color: var(--c-text); font-size: 18px; font-weight: 700; }
.sc__line-detail { display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: #9ca3af; }
.sc__subtotal--total { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 10px; }
.sc__total-label { font-size: 14px; color: var(--c-text); }
.sc__total-value-wrap { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
.sc__save-tag { font-size: 10px; font-weight: 700; color: #fff; background: #16a34a; border-radius: 999px; padding: 2px 8px; letter-spacing: 0.04em; }
.sc__coupon { display: grid; grid-template-columns: 1fr auto; gap: 8px; }
.sc__coupon-input { background: #0d0d0d; border: 1px solid #2a2a2a; border-radius: var(--r); min-height: 36px; padding: 0 10px; color: var(--c-text); font-size: 12px; }
.sc__coupon-btn { border: 1px solid #2a2a2a; border-radius: var(--r); background: #151515; color: #fff; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; padding: 0 12px; min-height: 36px; }
.sc__coupon-feedback { font-size: 11px; color: var(--c-muted); margin: 0; }
.sc__coupon-feedback.is-error { color: #f87171; }
.sc__coupon-feedback.is-success { color: #4ade80; }
.sc__checkout { width: 100%; padding: 14px; font-size: 12px; letter-spacing: 0.1em; }
.sc__warning { margin: 0; font-size: 11px; color: #fca5a5; }
.sc__view-cart {
  text-align: center; font-size: 12px; color: var(--c-muted);
  text-decoration: underline; text-underline-offset: 3px;
  transition: color var(--ease);
}
.sc__view-cart:hover { color: var(--c-text); }
</style>
