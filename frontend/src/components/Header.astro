  }
  .search-overlay :global(.search-results__cards) {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: stretch;
    gap: 16px;
    margin: 0;
    padding: 0 0 8px;
    list-style: none;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }
  .search-overlay :global(.search-results__cards > li) {
    flex: 0 0 auto;
    width: 140px;
    min-width: 140px;
  }
  .search-overlay :global(.search-result-card) {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease;
  }
  .search-overlay :global(.search-result-card:hover) {
    transform: translateY(-4px);
  }
  .search-overlay :global(.search-result-card__media) {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--c-bg-mute, #1a1a1a);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    margin-bottom: 12px;
  }
  .search-overlay :global(.search-result-card__img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .search-overlay :global(.search-result-card:hover .search-result-card__img) {
    transform: scale(1.06);
  }
  .search-overlay :global(.search-result-card__name) {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--c-text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-align: center;
    min-height: 2.6em;
  }
  .search-overlay :global(.search-results__empty) {
    width: 100%;
    color: var(--c-muted);
    font-size: 14px;
    padding: 20px 0;
    list-style: none;
  }

  /* Mobile menu */
  .mob-menu {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(320px, 90vw);
    background: var(--c-surface);
    z-index: 600;
    transform: translateX(-100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
    display: flex;
