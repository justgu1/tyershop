  }
  .mob-menu__sub:hover {
    color: var(--c-text);
  }
  .mob-menu__divider {
    height: 1px;
    background: var(--c-border);
    margin: 8px 20px;
  }
  .mob-menu__langs {
    display: flex;
    gap: 6px;
    padding: 14px 20px;
  }
  .mob-menu__lang-btn {
    font-size: 11px;
    font-weight: 700;
    color: var(--c-muted);
    padding: 6px 10px;
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    transition: all var(--ease);
  }
  .mob-menu__lang-btn.is-active {
    color: var(--c-accent);
    border-color: var(--c-accent);
  }
  .mob-menu__lang-btn:hover {
    color: var(--c-white);
    border-color: #444;
  }

  @media (max-width: 900px) {
    .hdr__inner {
      gap: 10px;
      padding-right: 8px;
    }
    .hdr__logo img {
      height: 30px;
    }
    .hdr__icon-btn {
      width: 36px;
      height: 36px;
    }
    .hdr__nav {
      display: none;
    }
    .hdr__lang {
      display: none;
    }
    .hdr__burger {
      display: flex;
      width: 36px;
      height: 36px;
      padding: 10px 8px;
    }
    /* `top`+`bottom` com antepassado filtrado (ex. backdrop no .hdr) faz o painel medir
       só a altura do header. Altura em dvh liga à viewport, não ao bloco de contenção. */
    .hdr__account-panel {
      position: fixed;
      top: 0;
      right: 0;
      left: 0;
      bottom: auto;
      width: 100%;
      min-width: 100%;
      min-height: 100vh;
      min-height: 100dvh;
      max-width: none;
      max-height: none;
      height: auto;
      border-radius: 0;
      border-left: 0;
      border-right: 0;
      border-bottom: 0;
      transform: translateX(100%);
      opacity: 1;
      visibility: visible;
      pointer-events: none;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      padding: 64px 20px 24px;
      z-index: 620;
      transition: transform 0.3s ease;
    }
    .hdr__account-wrap.is-open .hdr__account-panel {
      transform: translateX(0);
      pointer-events: all;
    }
    .hdr__account-close {
      position: absolute;
      top: 16px;
      right: 16px;
      width: 36px;
      height: 36px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--r);
      border: 1px solid var(--c-border);
      color: var(--c-muted);
      background: rgba(0, 0, 0, 0.2);
    }
    .hdr__account-name {
      display: none !important;
    }
    #hdr-auth-logged:not([hidden]) .hdr-auth-greeting:not([hidden]) {
      display: block;
    }
    .hdr-auth-logged__name--desktop {
      display: none !important;
    }
  }

  @media (min-width: 901px) {
    .hdr-auth-greeting {
      display: none !important;
    }
    .hdr-auth-logged__name--desktop {
      display: block !important;
    }
  }
</style>

<script
  define:vars={{
    publicKey:
      "pk_56a7e1a252f159acbc6c590a025dac7a69d4c869fd621f0273ad10c2a87e3975",
    medusaBase,
    resetSentHint,
    searchGroupNewest,
    searchGroupPopular,
    searchNoResults,
  }}
>
  // ── Header scroll ──
  const header = document.getElementById("site-header");
  function updateHeader() {
    if (header) header.classList.toggle("is-scrolled", window.scrollY > 10);
  }
  updateHeader();
  window.addEventListener("scroll", updateHeader, { passive: true });

  // ── Cart badge ──
  function updateBadge() {
    try {
      const items = JSON.parse(localStorage.getItem("tyer_cart") || "[]");
      const count = items.reduce((s, i) => s + (i.quantity || 0), 0);
      const badge = document.getElementById("cart-badge");
      if (badge) {
        badge.textContent = String(count);
        badge.dataset.count = String(count);
      }
    } catch {}
  }
  updateBadge();
  window.addEventListener("cart:update", updateBadge);

  // ── Account dropdown (login / registo / recuperar senha) ──
  const hdrWrap = document.getElementById("hdr-account-wrap");
  const hdrBtn = document.getElementById("hdr-account-btn");
  const hdrPanel = document.getElementById("hdr-account-panel");
  const hdrAuthLogged = document.getElementById("hdr-auth-logged");
  const hdrAuthForms = document.getElementById("hdr-auth-forms");
  const hdrProfileName = document.getElementById("hdr-profile-name");
  const hdrAuthGreeting = document.getElementById("hdr-auth-greeting");
  const hdrAccountName = document.getElementById("hdr-account-name");
  const hdrLoginForm = document.getElementById("hdr-login-form");
  const hdrRegForm = document.getElementById("hdr-register-form");
  const hdrForgotForm = document.getElementById("hdr-forgot-form");
  const hdrAuthMain = document.getElementById("hdr-auth-main");
  const hdrLoginStatus = document.getElementById("hdr-login-status");
  const hdrRegStatus = document.getElementById("hdr-reg-status");
  const hdrForgotStatus = document.getElementById("hdr-forgot-status");

  const storeJsonHeaders = {
    "Content-Type": "application/json",
    "x-publishable-api-key": publicKey,
  };
  const tResetSent = resetSentHint;
  // Mesma origem: proxy Vite (astro.config) encaminha /store e /auth ao Medusa — evita CORS no browser.
  const storeApiBase = "";
  async function readJsonSafe(res) {
    const ct = res.headers.get("content-type") || "";
    if (ct.includes("application/json")) {
      try { return await res.json(); } catch { return null; }
    }
    try {
      const text = await res.text();
      return { message: text && text.length < 220 ? text : "" };
    } catch {
      return null;
    }
  }

  function firstNameFromFullName(name) {
    const t = String(name || "").trim();
    if (!t) return "";
    return t.split(/\s+/)[0] || "";
  }

  function showAccountGuest() {
    if (hdrAuthLogged) hdrAuthLogged.hidden = true;
    if (hdrAuthForms) hdrAuthForms.hidden = false;
    if (hdrAuthGreeting) {
      hdrAuthGreeting.hidden = true;
      hdrAuthGreeting.textContent = "";
    }
    if (hdrAccountName) {
      hdrAccountName.hidden = true;
      hdrAccountName.textContent = "";
    }
  }

  function showAccountLogged(name) {
    if (hdrProfileName) hdrProfileName.textContent = name;
    const first = firstNameFromFullName(name);
    if (hdrAuthGreeting) {
      hdrAuthGreeting.textContent = first ? `Olá, ${first}` : "Olá";
      hdrAuthGreeting.hidden = false;
    }
    if (hdrAuthLogged) hdrAuthLogged.hidden = false;
    if (hdrAuthForms) hdrAuthForms.hidden = true;
    if (hdrAccountName) {
      hdrAccountName.hidden = false;
      hdrAccountName.textContent = name;
    }
  }

  async function syncAccountFromToken() {
    const token = localStorage.getItem("tyer_token");
    if (!token) {
      showAccountGuest();
      return;
    }
    try {
      const res = await fetch(`${storeApiBase}/store/customers/me`, {
        headers: {
          Authorization: `Bearer ${token}`,
          "x-publishable-api-key": publicKey,
        },
      });
      if (!res.ok) throw new Error("unauth");
      const data = await res.json();
      const c = data.customer;
      if (c) {
        localStorage.setItem("tyer_customer", JSON.stringify(c));
        const name = [c.first_name, c.last_name].filter(Boolean).join(" ").trim() || c.email;
        showAccountLogged(name);
        return;
      }
    } catch {
      /* token inválido */
    }
    localStorage.removeItem("tyer_token");
    localStorage.removeItem("tyer_customer");
    showAccountGuest();
  }
  syncAccountFromToken();

  if (hdrPanel) {
    hdrPanel.setAttribute("aria-hidden", "true");
  }
  let accountCloseTimer = null;
  function openAccountPanel() {
    if (!hdrWrap) return;
    if (accountCloseTimer) clearTimeout(accountCloseTimer);
    hdrWrap.classList.add("is-open");
    setAccountPanelOpen(true);
  }
  function scheduleCloseAccountPanel() {
    if (window.matchMedia("(max-width: 900px)").matches) return;
    accountCloseTimer = setTimeout(() => {
      if (hdrWrap && hdrWrap.contains(document.activeElement)) return;
      hdrWrap?.classList.remove("is-open");
      setAccountPanelOpen(false);
    }, 900);
  }
  function setAccountPanelOpen(isOpen) {
    if (!hdrPanel || !hdrBtn) return;
    hdrPanel.setAttribute("aria-hidden", isOpen ? "false" : "true");
    hdrBtn.setAttribute("aria-expanded", isOpen ? "true" : "false");
    if (window.matchMedia("(max-width: 900px)").matches) {
      document.body.style.overflow = isOpen ? "hidden" : "";
    }
  }
  if (hdrWrap) {
    hdrWrap.addEventListener("mouseenter", () => {
      if (!window.matchMedia("(min-width: 901px)").matches) return;
      openAccountPanel();
    });
    hdrWrap.addEventListener("mouseleave", () => {
      if (!window.matchMedia("(min-width: 901px)").matches) return;
      scheduleCloseAccountPanel();
    });
  }
  if (hdrPanel) {
    hdrPanel.addEventListener("mouseenter", () => {
      if (!window.matchMedia("(min-width: 901px)").matches) return;
      openAccountPanel();
    });
    hdrPanel.addEventListener("mouseleave", () => {
      if (!window.matchMedia("(min-width: 901px)").matches) return;
      scheduleCloseAccountPanel();
    });
  }
  if (hdrBtn) {
    hdrBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (window.matchMedia("(min-width: 901px)").matches) {
        openAccountPanel();
        return;
      }
      const open = !hdrWrap?.classList.contains("is-open");
      hdrWrap?.classList.toggle("is-open", open);
      setAccountPanelOpen(open);
    });
  }
  document.getElementById("hdr-account-close")?.addEventListener("click", () => {
    hdrWrap?.classList.remove("is-open");
    setAccountPanelOpen(false);
    document.body.style.overflow = "";
  });
  document.addEventListener("click", (e) => {
    if (!hdrWrap || !e.target) return;
    if (window.matchMedia("(min-width: 901px)").matches) return;
    if (hdrWrap.contains(e.target)) return;
    hdrWrap.classList.remove("is-open");
    setAccountPanelOpen(false);
  });

  document.querySelectorAll(".hdr-auth-tab").forEach((tab) => {
    tab.addEventListener("click", () => {
      document.querySelectorAll(".hdr-auth-tab").forEach((t) => {
        t.classList.remove("is-active");
        t.setAttribute("aria-selected", "false");
      });
      tab.classList.add("is-active");
      tab.setAttribute("aria-selected", "true");
      const which = tab.getAttribute("data-tab");
      if (hdrLoginForm) hdrLoginForm.hidden = which !== "login";
      if (hdrRegForm) hdrRegForm.hidden = which !== "register";
    });
  });

  document.getElementById("hdr-forgot-open")?.addEventListener("click", () => {
    if (hdrAuthMain) hdrAuthMain.hidden = true;
    if (hdrForgotForm) {
      hdrForgotForm.hidden = false;
    }
    document.querySelector(".hdr-auth-tabs")?.setAttribute("hidden", "");
  });
  document.getElementById("hdr-forgot-back")?.addEventListener("click", () => {
    if (hdrForgotForm) hdrForgotForm.hidden = true;
    if (hdrAuthMain) hdrAuthMain.hidden = false;
    document.querySelector(".hdr-auth-tabs")?.removeAttribute("hidden");
  });

  if (hdrLoginForm) {
    hdrLoginForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(hdrLoginForm);
      const email = String(fd.get("email") || "");
      const password = String(fd.get("password") || "");
      if (hdrLoginStatus) {
        hdrLoginStatus.hidden = false;
        hdrLoginStatus.textContent = "…";
      }
      try {
        const res = await fetch(`${storeApiBase}/auth/customer/emailpass`, {
          method: "POST",
          headers: storeJsonHeaders,
          body: JSON.stringify({ email, password }),
        });
        const data = await readJsonSafe(res);
        if (!res.ok) throw new Error(data?.message || "Falha no login");
        const token = data.token;
        if (!token) throw new Error("Resposta inválida");
        localStorage.setItem("tyer_token", token);
        await syncAccountFromToken();
        if (hdrLoginStatus) hdrLoginStatus.textContent = "";
        if (hdrLoginStatus) hdrLoginStatus.hidden = true;
      } catch (err) {
        if (hdrLoginStatus)
          hdrLoginStatus.textContent =
            err instanceof Error ? err.message : "Email ou senha inválidos.";
      }
    });
  }

  if (hdrRegForm) {
    hdrRegForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(hdrRegForm);
      const first_name = String(fd.get("first_name") || "");
      const last_name = String(fd.get("last_name") || "");
      const email = String(fd.get("email") || "");
      const password = String(fd.get("password") || "");
      if (hdrRegStatus) {
        hdrRegStatus.hidden = false;
        hdrRegStatus.textContent = "…";
      }
      try {
        const reg = await fetch(`${storeApiBase}/auth/customer/emailpass/register`, {
          method: "POST",
          headers: storeJsonHeaders,
          body: JSON.stringify({ email, password }),
        });
        const regData = await readJsonSafe(reg);
        if (!reg.ok) throw new Error(regData?.message || "Registo falhou");
        const regToken = regData.token;
        if (!regToken) throw new Error("Sem token de registo");
        const create = await fetch(`${storeApiBase}/store/customers`, {
          method: "POST",
          headers: {
            ...storeJsonHeaders,
            Authorization: `Bearer ${regToken}`,
          },
          body: JSON.stringify({ email, first_name, last_name }),
        });
        const createData = await readJsonSafe(create);
        if (!create.ok) throw new Error(createData?.message || "Não foi possível criar a conta");
        const loginRes = await fetch(`${storeApiBase}/auth/customer/emailpass`, {
          method: "POST",
          headers: storeJsonHeaders,
          body: JSON.stringify({ email, password }),
        });
        const loginData = await readJsonSafe(loginRes);
        if (!loginRes.ok || !loginData.token) throw new Error("Conta criada; faça login");
        localStorage.setItem("tyer_token", loginData.token);
        await syncAccountFromToken();
        if (hdrRegStatus) hdrRegStatus.textContent = "";
        if (hdrRegStatus) hdrRegStatus.hidden = true;
      } catch (err) {
        if (hdrRegStatus)
          hdrRegStatus.textContent = err instanceof Error ? err.message : "Erro";
      }
    });
  }

  if (hdrForgotForm) {
    hdrForgotForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = String(
        (document.getElementById("hdr-forgot-email") instanceof HTMLInputElement &&
          document.getElementById("hdr-forgot-email").value) ||
          ""
      );
      if (hdrForgotStatus) {
        hdrForgotStatus.hidden = false;
        hdrForgotStatus.textContent = "…";
      }
      try {
        const res = await fetch(
          `${storeApiBase}/auth/customer/emailpass/reset-password`,
          {
            method: "POST",
            headers: { ...storeJsonHeaders, accept: "text/plain" },
            body: JSON.stringify({ identifier: email }),
          }
        );
        if (hdrForgotStatus)
          hdrForgotStatus.textContent =
            res.status < 500
              ? tResetSent
              : "Não foi possível enviar. Tente novamente.";
      } catch {
        if (hdrForgotStatus) hdrForgotStatus.textContent = tResetSent;
      }
    });
  }

  document.getElementById("hdr-logout-btn")?.addEventListener("click", () => {
    localStorage.removeItem("tyer_token");
    localStorage.removeItem("tyer_customer");
    showAccountGuest();
    window.location.reload();
  });

  // ── Cart open ──
  document.getElementById("cart-toggle")?.addEventListener("click", () => {
    const sc = document.getElementById("side-cart");
    const bd = document.getElementById("side-cart-backdrop");
    if (sc) {
      sc.classList.add("is-open");
      sc.setAttribute("aria-hidden", "false");
    }
    if (bd) {
      bd.classList.add("is-active");
    }
    document.body.style.overflow = "hidden";
  });

  // ── Search overlay ──
  const searchOverlay = document.getElementById("search-overlay");
  const searchInput = document.getElementById("search-input");
  const searchBackdrop = document.getElementById("search-backdrop");
  const searchResultsEl = document.getElementById("search-results");
  const searchResultsList = document.getElementById("search-results-list");
  const searchRecentsEl = document.getElementById("search-recents");
  const searchRecentsList = document.getElementById("search-recents-list");

  const RECENT_KEY = "tyer_searches";
  const VISITED_KEY = "tyer_visited";
  let discoverCache = null;
  function escapeHtml(value) {
    return String(value || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function getRecents() {
    try {
      return JSON.parse(localStorage.getItem(RECENT_KEY) || "[]");
    } catch {
      return [];
    }
  }
  function saveRecent(q) {
    const list = [q, ...getRecents().filter((r) => r !== q)].slice(0, 6);
    localStorage.setItem(RECENT_KEY, JSON.stringify(list));
  }

  function renderRecents() {
    const list = getRecents();
    if (searchRecentsList) searchRecentsList.innerHTML = "";
    if (!list.length) {
      if (searchRecentsEl) searchRecentsEl.hidden = true;
      return;
    }
    if (searchRecentsEl) searchRecentsEl.hidden = false;
    list.forEach((term) => {
      const btn = document.createElement("button");
      btn.className = "search-recent-tag";
      btn.innerHTML = `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-.41-5.62"/></svg>${term}`;
      btn.addEventListener("click", () => {
        if (searchInput) {
          searchInput.value = term;
          doSearch(term);
        }
      });
      if (searchRecentsList) searchRecentsList.appendChild(btn);
    });
  }

  let searchTimer = null;
  async function fetchDiscoverProducts() {
    if (discoverCache) return discoverCache;
    const headers = { "x-publishable-api-key": publicKey };
    const res = await fetch(`/store/products?limit=24`, { headers });
    if (!res.ok) return { newest: [], popular: [] };
    const data = await res.json();
    const products = Array.isArray(data.products) ? data.products : [];
    const newest = [...products]
      .sort((a, b) => new Date(b?.created_at || 0).getTime() - new Date(a?.created_at || 0).getTime())
      .slice(0, 4);
    const popular = [...products]
      .sort((a, b) => {
        const aScore = Number(a?.metadata?.sales_count || a?.metadata?.total_sales || a?.sold_count || 0);
        const bScore = Number(b?.metadata?.sales_count || b?.metadata?.total_sales || b?.sold_count || 0);
        return bScore - aScore;
      })
      .slice(0, 4);
    discoverCache = { newest, popular };
    return discoverCache;
  }

  function renderSearchProductsGroup(title, products) {
    if (!products?.length) return "";
    const items = products
      .map((p) => {
        const thumb = escapeHtml(p?.thumbnail || "/logo.webp");
        const label = escapeHtml(p?.title || "");
        const handle = escapeHtml(p?.handle || "");
        return `<li role="listitem"><a class="search-result-card" href="/product/${handle}">
          <div class="search-result-card__media">
            <img class="search-result-card__img" src="${thumb}" alt="" width="240" height="240" loading="lazy" decoding="async" />
          </div>
          <span class="search-result-card__name">${label}</span>
        </a></li>`;
      })
      .join("");
    const head = escapeHtml(title);
    return `<li class="search-results__section" role="presentation">
      <div class="search-results__group-label">${head}</div>
      <ul class="search-results__cards" role="list">${items}</ul>
    </li>`;
  }

  async function renderDiscoverFallback() {
    try {
      const data = await fetchDiscoverProducts();
      if (searchResultsEl) searchResultsEl.hidden = false;
      if (searchRecentsEl) searchRecentsEl.hidden = false;
      if (searchResultsList) {
        searchResultsList.innerHTML =
          renderSearchProductsGroup(searchGroupNewest, data.newest) +
          renderSearchProductsGroup(searchGroupPopular, data.popular);
      }
    } catch {
      if (searchResultsEl) searchResultsEl.hidden = true;
    }
  }

  async function doSearch(q) {
    if (!q.trim()) {
      renderRecents();
      await renderDiscoverFallback();
      return;
    }
    if (searchRecentsEl) searchRecentsEl.hidden = true;
    try {
      const headers = {
        "x-publishable-api-key": publicKey,
      };
      const res = await fetch(
        `/store/products?q=${encodeURIComponent(q)}&limit=8`,
        { headers },
      );
      if (!res.ok) return;
      const data = await res.json();
      const products = data.products;
      if (searchResultsEl) searchResultsEl.hidden = false;
      if (searchResultsList) searchResultsList.innerHTML = "";
      if (!products || !products.length) {
        if (searchResultsList)
          searchResultsList.innerHTML = `<li class="search-results__empty" role="status">${escapeHtml(searchNoResults)}</li>`;
        return;
      }
      const cardItems = products
        .map((p) => {
          const thumb = escapeHtml(p.thumbnail || "/logo.webp");
          const title = escapeHtml(p.title || "");
          const handle = escapeHtml(p.handle || "");
          return `<li role="listitem"><a class="search-result-card" href="/product/${handle}">
          <div class="search-result-card__media">
            <img class="search-result-card__img" src="${thumb}" alt="" width="240" height="240" loading="lazy" decoding="async" />
          </div>
          <span class="search-result-card__name">${title}</span>
        </a></li>`;
        })
        .join("");
      if (searchResultsList) {
        searchResultsList.innerHTML = `<li class="search-results__section search-results__section--solo" role="presentation"><ul class="search-results__cards" role="list">${cardItems}</ul></li>`;
      }
    } catch {}
  }

  if (searchInput) {
    searchInput.addEventListener("input", () => {
      if (searchTimer) clearTimeout(searchTimer);
      searchTimer = setTimeout(() => doSearch(searchInput.value), 280);
    });
    searchInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && searchInput.value.trim()) {
        saveRecent(searchInput.value.trim());
        doSearch(searchInput.value);
      }
    });
  }

  function openSearch() {
    searchOverlay.classList.add("is-open");
    searchOverlay.setAttribute("aria-hidden", "false");
    searchBackdrop.classList.add("is-active");
    document.body.style.overflow = "hidden";
    renderRecents();
    renderDiscoverFallback();
    setTimeout(() => searchInput?.focus(), 50);
    document
      .getElementById("search-toggle")
      ?.setAttribute("aria-expanded", "true");
  }
  function closeSearch() {
    searchOverlay.classList.remove("is-open");
    searchOverlay.setAttribute("aria-hidden", "true");
    searchBackdrop.classList.remove("is-active");
    document.body.style.overflow = "";
    document
      .getElementById("search-toggle")
      ?.setAttribute("aria-expanded", "false");
  }
  document
    .getElementById("search-toggle")
    ?.addEventListener("click", openSearch);
  document
    .getElementById("search-close")
    ?.addEventListener("click", closeSearch);
  searchBackdrop?.addEventListener("click", closeSearch);

  // ── Mobile menu ──
  const mobMenu = document.getElementById("mobile-menu");
  const mobBackdrop = document.getElementById("menu-backdrop");
  const burger = document.getElementById("menu-toggle");
  function openMob() {
    mobMenu?.classList.add("is-open");
    mobBackdrop?.classList.add("is-active");
    burger?.classList.add("is-open");
    burger?.setAttribute("aria-expanded", "true");
    mobMenu?.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }
  function closeMob() {
    mobMenu?.classList.remove("is-open");
    mobBackdrop?.classList.remove("is-active");
    burger?.classList.remove("is-open");
    burger?.setAttribute("aria-expanded", "false");
    mobMenu?.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }
  burger?.addEventListener("click", () => {
    const isOpen = mobMenu?.classList.contains("is-open");
    if (isOpen) closeMob();
    else openMob();
  });
  document.getElementById("menu-close")?.addEventListener("click", closeMob);
  mobBackdrop?.addEventListener("click", closeMob);
  mobMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => closeMob());
  });

  // ── Escape key ──
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closeSearch();
      closeMob();
      if (hdrWrap?.classList.contains("is-open")) {
        hdrWrap.classList.remove("is-open");
        setAccountPanelOpen(false);
      }
    }
  });

  // ── Megamenu hover delay (2s after mouseleave) ──
  const megaWrap = document.getElementById("nav-collections-wrap");
  const mega = document.getElementById("mega-collections");
  let megaCloseTimer = null;
  if (megaWrap && mega) {
    megaWrap.addEventListener("mouseenter", () => {
      if (document.body.classList.contains("shop-sidebar-open")) return;
      if (megaCloseTimer) clearTimeout(megaCloseTimer);
      megaWrap.classList.add("is-hovered");
      header?.classList.add("is-mega-open");
    });
    megaWrap.addEventListener("mouseleave", () => {
      megaCloseTimer = setTimeout(() => {
        megaWrap.classList.remove("is-hovered");
        header?.classList.remove("is-mega-open");
      }, 500);
    });
    mega.addEventListener("mouseenter", () => {
      if (document.body.classList.contains("shop-sidebar-open")) return;
      if (megaCloseTimer) clearTimeout(megaCloseTimer);
      megaWrap.classList.add("is-hovered");
      header?.classList.add("is-mega-open");
    });
    mega.addEventListener("mouseleave", () => {
      megaCloseTimer = setTimeout(() => {
        megaWrap.classList.remove("is-hovered");
        header?.classList.remove("is-mega-open");
      }, 500);
    });
  }

  // ── Active nav ──
  const path = window.location.pathname;
  document.querySelectorAll(".hdr__nav-link").forEach((a) => {
    const href = a.getAttribute("href");
    if (href && path.startsWith(href) && href !== "/") {
      a.classList.add("is-active");
    }
  });

  // ── Megamenu preview image swap on hover ──
  const previewImg = document.getElementById("mega-preview-img");
  const megaItems = document.querySelectorAll(".mega__item");

  if (previewImg && megaItems.length) {
    // Mark first item as active on initial render
    megaItems[0]?.classList.add("is-active");

    megaItems.forEach((item) => {
      item.addEventListener("mouseenter", () => {
        const img = item.dataset.img;
        if (!img || previewImg.src.endsWith(img)) return;

        // Cross-fade the image
        previewImg.classList.add("is-transitioning");
        setTimeout(() => {
          previewImg.src = img;
          previewImg.alt =
            item.querySelector(".mega__item-name")?.textContent || "";
          previewImg.classList.remove("is-transitioning");
        }, 60);

        // Mark active
        megaItems.forEach((i) => i.classList.remove("is-active"));
        item.classList.add("is-active");
      });
    });
  }
</script>
