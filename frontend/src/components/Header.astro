  }
  .search-overlay__input::placeholder {
    color: #444;
  }
  .search-overlay__close {
    color: var(--c-muted);
    padding: 6px;
    border-radius: var(--r);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      color var(--ease),
      background var(--ease);
  }
  .search-overlay__close:hover {
    color: var(--c-white);
    background: rgba(255, 255, 255, 0.08);
  }
  .search-overlay__body {
    padding-top: 24px;
  }
  .search-section-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-muted);
    margin-bottom: 12px;
  }
  .search-recents__list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .search-recent-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border: 1px solid #222;
    border-radius: 99px;
    font-size: 12px;
    color: var(--c-text);
    transition:
      border-color var(--ease),
      color var(--ease);
    cursor: pointer;
  }
  .search-recent-tag:hover {
    border-color: var(--c-accent);
    color: var(--c-accent);
  }
  .search-results__list {
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding: 8px 0 0;
    margin: 0;
    list-style: none;
  }
  /*
   * Resultados montados via innerHTML não recebem data-astro do scope;
   * precisam de :global dentro de .search-overlay para o flex em linha valer.
   */
  .search-overlay :global(.search-results__section) {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    min-width: 0;
    list-style: none;
  }
  .search-overlay :global(.search-results__group-label) {
    display: block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
