---
import { t, getPathForLang, type Lang } from "../i18n/utils";

interface NavDrop {
  handle: string;
  name: string;
  num: string;
  img: string;
}

interface Props {
  lang?: Lang;
  drops: NavDrop[];
}
const lang: Lang = Astro.props.lang ?? "pt";
const drops: NavDrop[] = Array.isArray(Astro.props.drops) ? Astro.props.drops : [];

const url =
  import.meta.env.MEDUSA_INTERNAL_URL ||
  import.meta.env.MEDUSA_URL ||
  "http://localhost:9003";
const medusaBase = (
  import.meta.env.PUBLIC_MEDUSA_URL || url
).replace(/\/$/, "");
const resetSentHint = t(lang, "account", "reset_sent_hint");
const searchRecentsTitle = t(lang, "search", "recents_title");
const searchCloseAria = t(lang, "search", "close_aria");
const searchResultsAria = t(lang, "search", "results_aria");
const searchNoResults = t(lang, "search", "no_results");
const searchGroupNewest = t(lang, "search", "group_newest");
const searchGroupPopular = t(lang, "search", "group_popular");
---

<header class="hdr" id="site-header">
  <div class="hdr__inner container">
    <!-- Logo -->
    <a
      href={getPathForLang("/", lang)}
      class="hdr__logo"
      aria-label="Tyer — Home"
    >
      <img src="/logo.webp" alt="Tyer" width="100" height="44" />
    </a>

    <!-- Nav -->
    <nav class="hdr__nav" aria-label="Main navigation">
      {drops.length > 0 && (
        <div class="hdr__nav-item hdr__nav-item--mega" id="nav-collections-wrap">
          <a
            href={getPathForLang("/#collection", lang)}
            class="hdr__nav-link"
            aria-haspopup="true"
            aria-expanded="false"
            id="nav-collections-btn"
          >
            {t(lang, "nav", "collections")}
            <svg
              class="hdr__nav-chevron"
              width="10"
              height="10"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg
            >
          </a>
          <div
            class="mega"
            id="mega-collections"
            role="region"
            aria-label="Collections"
            aria-hidden="true"
          >
            <div class="mega__inner container">
              <ul class="mega__list" role="list">
                {
                  drops.map((drop, i) => (
                    <li>
                      <a
                        href={getPathForLang(`/collections/${drop.handle}`, lang)}
                        class={`mega__item${i === 0 ? " is-preloaded" : ""}`}
                        data-img={drop.img}
                        data-num={drop.num}
                      >
                        <span class="mega__item-num">{drop.num}</span>
                        <span class="mega__item-name">{drop.name}</span>
                        <svg
                          class="mega__item-arrow"
                          width="14"
                          height="14"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          aria-hidden="true"
                        >
                          <path d="m9 18 6-6-6-6" />
                        </svg>
                      </a>
                    </li>
                  ))
                }
              </ul>
              <div class="mega__preview">
                <img
                  src={drops[0]?.img || "/logo.webp"}
                  alt={drops[0]?.name || "Preview"}
                  id="mega-preview-img"
                  class="mega__preview-img"
                  width="320"
                  height="420"
                  loading="eager"
                  decoding="async"
                />
              </div>
            </div>
          </div>
        </div>
      )}

      <a href={getPathForLang("/shop", lang)} class="hdr__nav-link"
        >{t(lang, "nav", "shop")}</a
      >
      <a
        href={`${getPathForLang("/", lang)}#editorial`}
        class="hdr__nav-link"
        data-scroll-anchor="true">{t(lang, "nav", "editorial")}</a
      >
    </nav>

    <!-- Actions -->
    <div class="hdr__actions">
      <!-- Search -->
      <button
        class="hdr__icon-btn"
        id="search-toggle"
        aria-label={t(lang, "nav", "search")}
        aria-expanded="false"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"
          ></path></svg
        >
      </button>
      <!-- Cart -->
      <button
        class="hdr__icon-btn"
        id="cart-toggle"
        aria-label={t(lang, "nav", "cart")}
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          ><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"
          ></path><line x1="3" y1="6" x2="21" y2="6"></line><path
            d="M16 10a4 4 0 0 1-8 0"></path></svg
        >
        <span
          class="hdr__cart-badge"
          id="cart-badge"
          data-count="0"
          aria-hidden="true">0</span
        >
      </button>
      <!-- Account (hover no desktop, clique no mobile) -->
      <div class="hdr__account-wrap" id="hdr-account-wrap" data-orders-href={getPathForLang("/account/orders", lang)}>
        <button
          type="button"
          class="hdr__icon-btn"
          id="hdr-account-btn"
          aria-label={t(lang, "nav", "account")}
          aria-expanded="false"
          aria-controls="hdr-account-panel"
          aria-haspopup="dialog"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
            ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle
              cx="12"
              cy="7"
              r="4"></circle></svg
          >
        </button>
        <span class="hdr__account-name" id="hdr-account-name" hidden></span>
        <div
          class="hdr__account-panel"
          id="hdr-account-panel"
          role="dialog"
          aria-label={t(lang, "account", "my_account")}
          aria-hidden="true"
        >
          <button type="button" class="hdr__account-close" id="hdr-account-close" aria-label={t(lang, "nav", "close_menu")}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"></path></svg>
          </button>
          <div id="hdr-auth-logged" class="hdr-auth-logged" hidden>
            <p class="hdr-auth-greeting" id="hdr-auth-greeting" hidden></p>
            <p class="hdr-auth-logged__name hdr-auth-logged__name--desktop" id="hdr-profile-name"></p>
            <a
              class="btn btn-outline hdr-auth-logged__btn"
              href={getPathForLang("/account", lang)}>{t(lang, "account", "my_account")}</a
            >
            <a
              class="btn btn-outline hdr-auth-logged__btn"
              id="hdr-orders-link"
              href={getPathForLang("/account/orders", lang)}>{t(lang, "account", "order_history")}</a
            >
            <button type="button" class="btn btn-primary hdr-auth-logged__btn" id="hdr-logout-btn"
              >{t(lang, "account", "logout")}</button
            >
          </div>
          <div id="hdr-auth-forms">
            <div class="hdr-auth-tabs" role="tablist" aria-label={t(lang, "account", "my_account")}>
              <button
                type="button"
                class="hdr-auth-tab is-active"
                id="hdr-tab-login"
                role="tab"
                data-tab="login"
                aria-selected="true"
                >{t(lang, "account", "login")}</button
              >
              <button
                type="button"
                class="hdr-auth-tab"
                id="hdr-tab-register"
                role="tab"
                data-tab="register"
                aria-selected="false"
                >{t(lang, "account", "register")}</button
              >
            </div>
            <div id="hdr-auth-main">
              <form class="hdr-auth-form" id="hdr-login-form" novalidate>
                <div class="hdr-auth-field">
                  <label for="hdr-login-email">{t(lang, "account", "email")}</label>
                  <input
                    type="email"
                    id="hdr-login-email"
                    name="email"
                    autocomplete="email"
                    required
                  />
                </div>
                <div class="hdr-auth-field">
                  <label for="hdr-login-password">{t(lang, "account", "password")}</label>
                  <input
                    type="password"
                    id="hdr-login-password"
                    name="password"
                    autocomplete="current-password"
                    required
                  />
                </div>
                <p class="hdr-auth-status" id="hdr-login-status" aria-live="polite" hidden></p>
                <button type="submit" class="btn btn-primary hdr-auth-submit"
                  >{t(lang, "account", "login")}</button
                >
                <button type="button" class="hdr-auth-link" id="hdr-forgot-open"
                  >{t(lang, "account", "forgot_password")}</button
                >
              </form>
              <form class="hdr-auth-form" id="hdr-register-form" hidden novalidate>
                <div class="hdr-auth-field">
                  <label for="hdr-reg-first">{t(lang, "account", "first_name")}</label>
                  <input type="text" id="hdr-reg-first" name="first_name" autocomplete="given-name" required />
                </div>
                <div class="hdr-auth-field">
                  <label for="hdr-reg-last">{t(lang, "account", "last_name")}</label>
                  <input type="text" id="hdr-reg-last" name="last_name" autocomplete="family-name" required />
                </div>
                <div class="hdr-auth-field">
                  <label for="hdr-reg-email">{t(lang, "account", "email")}</label>
                  <input type="email" id="hdr-reg-email" name="email" autocomplete="email" required />
                </div>
                <div class="hdr-auth-field">
                  <label for="hdr-reg-password">{t(lang, "account", "password")}</label>
                  <input
                    type="password"
                    id="hdr-reg-password"
                    name="password"
                    autocomplete="new-password"
                    required
                    minlength="8"
                  />
                </div>
                <p class="hdr-auth-status" id="hdr-reg-status" aria-live="polite" hidden></p>
                <button type="submit" class="btn btn-primary hdr-auth-submit"
                  >{t(lang, "account", "register")}</button
                >
              </form>
            </div>
            <form class="hdr-auth-form hdr-auth-form--forgot" id="hdr-forgot-form" hidden novalidate>
              <p class="hdr-auth-forgot-hint">{t(lang, "account", "forgot_password")}</p>
              <div class="hdr-auth-field">
                <label for="hdr-forgot-email">{t(lang, "account", "email")}</label>
                <input type="email" id="hdr-forgot-email" name="email" autocomplete="email" required />
              </div>
              <p class="hdr-auth-status" id="hdr-forgot-status" aria-live="polite" hidden></p>
              <button type="submit" class="btn btn-primary hdr-auth-submit"
                >{t(lang, "account", "send_reset")}</button
              >
              <button type="button" class="hdr-auth-link" id="hdr-forgot-back"
                >{t(lang, "account", "back_to_login")}</button
              >
            </form>
          </div>
        </div>
      </div>
      <!-- Burger -->
      <button
        class="hdr__burger"
        id="menu-toggle"
        aria-label={t(lang, "nav", "open_menu")}
        aria-expanded="false"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<!-- Search overlay -->
<div
  class="search-overlay"
  id="search-overlay"
  aria-hidden="true"
  role="dialog"
  aria-label={t(lang, "nav", "search")}
>
  <div class="search-overlay__inner container">
    <div class="search-overlay__bar">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
        ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"
        ></path></svg
      >
      <input
        type="search"
        class="search-overlay__input"
        id="search-input"
        placeholder={`${t(lang, "nav", "search")}…`}
        aria-label={t(lang, "nav", "search")}
        autocomplete="off"
      />
      <button
        class="search-overlay__close"
        id="search-close"
        aria-label={searchCloseAria}
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"></path></svg
        >
      </button>
    </div>
    <div class="search-overlay__body" id="search-body">
      <div class="search-recents" id="search-recents">
        <p class="search-section-title">{searchRecentsTitle}</p>
        <ul class="search-recents__list" id="search-recents-list" role="list">
        </ul>
      </div>
      <div class="search-results" id="search-results" hidden>
        <ul
          class="search-results__list"
          id="search-results-list"
          role="list"
          aria-label={searchResultsAria}
        >
        </ul>
      </div>
    </div>
  </div>
</div>
<div class="backdrop" id="search-backdrop" aria-hidden="true"></div>

<!-- Mobile menu -->
<nav
  class="mob-menu"
  id="mobile-menu"
  aria-label="Mobile menu"
  aria-hidden="true"
>
  <div class="mob-menu__header">
    <a href={getPathForLang("/", lang)} class="mob-menu__logo">
      <img src="/logo-white.png" alt="Tyer" width="80" height="36" />
    </a>
    <button
      class="mob-menu__close"
      id="menu-close"
      aria-label={t(lang, "nav", "close_menu")}
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"><path d="M18 6 6 18M6 6l12 12"></path></svg
      >
    </button>
  </div>
  <ul class="mob-menu__list">
    {drops.length > 0 && (
      <li>
        <a
          href={getPathForLang("/#collection", lang)}
          class="mob-menu__link">{t(lang, "nav", "collections")}</a>
      </li>
    )}
    <li>
      <a href={getPathForLang("/#editorial", lang)} class="mob-menu__link">{t(lang, "nav", "editorial")}</a>
    </li>
    {drops.length > 0 &&
      drops.map((d) => (
        <li>
          <a
            href={getPathForLang(`/collections/${d.handle}`, lang)}
            class="mob-menu__sub"
          >
            {d.name}
          </a>
        </li>
      ))
    }
    <li class="mob-menu__divider" role="separator"></li>
    <li>
      <a href={getPathForLang("/shop", lang)} class="mob-menu__link"
        >{t(lang, "nav", "shop")}</a>
    </li>
    <li>
      <a href={getPathForLang("/faq", lang)} class="mob-menu__link">FAQ</a>
    </li>
    <li>
      <a href={getPathForLang("/terms", lang)} class="mob-menu__link">Termos</a>
    </li>
    <li>
      <a href={getPathForLang("/privacy", lang)} class="mob-menu__link">Privacidade</a>
    </li>
    <li>
      <a href={getPathForLang("/returns", lang)} class="mob-menu__link">Trocas e devoluções</a>
    </li>
  </ul>
</nav>
<div class="backdrop" id="menu-backdrop" aria-hidden="true"></div>

<style>
  /* ── Header ── */
  .hdr {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 500;
    height: var(--header-h);
    background: transparent;
    transition:
      background 0.35s ease,
      border-color 0.35s ease;
    border-bottom: 1px solid transparent;
    overflow-x: clip;
  }
  .hdr.is-scrolled {
    background: rgba(8, 8, 8, 0.94);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom-color: #1e1e1e;
  }
  .hdr.is-mega-open {
    background: rgba(8, 8, 8, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom-color: #1e1e1e;
  }
  body.page-shop .hdr {
    background: rgba(8, 8, 8, 0.94);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom-color: #1e1e1e;
  }
  .hdr__inner {
    height: 100%;
    display: flex;
    align-items: center;
    gap: 32px;
    width: 100%;
    min-width: 0;
  }
  .hdr__logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .hdr__logo img {
    height: 36px;
    width: auto;
    object-fit: contain;
  }

  /* Nav */
  .hdr__nav {
    display: flex;
    align-items: center;
    gap: 0;
    flex: 1;
  }
  .hdr__nav-item {
    position: relative;
  }
  .hdr__nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 14px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    border-radius: var(--r);
    transition: color var(--ease);
    cursor: pointer;
  }
  .hdr__nav-link:hover,
  .hdr__nav-link.is-active {
    color: var(--c-white);
  }
  .hdr__nav-link.is-active {
    position: relative;
  }
  .hdr__nav-link.is-active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 14px;
    right: 14px;
    height: 1.5px;
    background: var(--c-accent);
    border-radius: 99px;
  }
  .hdr__nav-chevron {
    transition: transform 0.2s;
    opacity: 0.6;
  }
  .hdr__nav-item--mega:hover .hdr__nav-chevron {
    transform: rotate(180deg);
  }

  /* Megamenu */
  .mega {
    position: fixed;
    top: var(--header-h);
    left: 0;
    right: 0;
    background: rgba(8, 8, 8, 0.97);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid #1e1e1e;
    opacity: 0;
    transform: translateY(-6px);
    pointer-events: none;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
    z-index: 490;
    padding: 32px 0;
  }
  .hdr__nav-item--mega:hover .mega,
  .hdr__nav-item--mega.is-hovered .mega,
  .mega:hover {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }
  .mega__inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 48px;
    align-items: start;
    padding-block: 8px;
  }

  /* List of collection titles — 2 columns */
  .mega__list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px 16px;
  }
  .mega__item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: var(--r-md);
    transition:
      background var(--ease),
      color var(--ease);
    color: rgba(255, 255, 255, 0.5);
    font-size: 13px;
  }
  .mega__item:hover,
  .mega__item.is-active {
    background: rgba(255, 255, 255, 0.05);
    color: var(--c-white);
  }
  .mega__item-num {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--c-accent);
    min-width: 24px;
  }
  .mega__item-name {
    font-size: 14px;
    font-weight: 600;
    flex: 1;
  }
  .mega__item-arrow {
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity var(--ease),
      transform var(--ease);
  }
  .mega__item:hover .mega__item-arrow,
  .mega__item.is-active .mega__item-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* Preview image (right side) */
  .mega__preview {
    width: 100%;
    aspect-ratio: 3/4;
    border-radius: var(--r-md);
    overflow: hidden;
    background: #111;
    position: relative;
  }
  .mega__preview-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%);
    transition:
      opacity 0.3s ease,
      transform 0.4s ease;
  }
  .mega__preview-img.is-transitioning {
    opacity: 0;
    transform: scale(1.04);
  }

  /* Actions */
  .hdr__actions {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: auto;
    flex-shrink: 0;
  }
  .hdr__icon-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--r);
    color: rgba(255, 255, 255, 0.65);
    transition:
      color var(--ease),
      background var(--ease);
  }
  .hdr__icon-btn:hover {
    color: var(--c-white);
    background: rgba(255, 255, 255, 0.08);
  }
  .hdr__cart-badge {
    position: absolute;
    top: 5px;
    right: 5px;
    background: var(--c-accent);
    color: var(--c-white);
    font-size: 8px;
    font-weight: 800;
    min-width: 14px;
    height: 14px;
    border-radius: 99px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    line-height: 1;
  }
  .hdr__cart-badge[data-count="0"] {
    display: none;
  }

  .hdr__account-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .hdr__account-name {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.82);
    max-width: 120px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .hdr__account-panel {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    width: min(320px, 92vw);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    padding: 20px 18px;
    z-index: 520;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-6px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      visibility 0.2s;
  }
  .hdr__account-close { display: none; }
  .hdr__account-wrap.is-open .hdr__account-panel {
    opacity: 1;
    visibility: visible;
    pointer-events: all;
    transform: translateY(0);
  }
  .hdr__account-panel[aria-hidden="true"] { pointer-events: none; }
  .hdr__account-panel [hidden],
  .hdr__account-panel[hidden] { display: none !important; }
  .hdr-auth-tabs {
    display: flex;
    gap: 0;
