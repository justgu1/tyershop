  }
  .mob-menu.is-open {
    transform: translateX(0);
  }
  .mob-menu__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    border-bottom: 1px solid var(--c-border);
  }
  .mob-menu__logo img {
    height: 30px;
