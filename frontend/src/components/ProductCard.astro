---
import { t, getPathForLang, type Lang } from '../i18n/utils';
import { getVariantGalleryUrls } from '../lib/product-variant-gallery';
import { getProductVariantData, getVariantMaxQty, isVariantSoldOut } from '../lib/product-variants';

interface Props {
  product: any;
  lang?: Lang;
  role?: 'article' | 'listitem';
  badges?: {
    isPopular?: boolean;
    isNew?: boolean;
  };
} 

const { product, lang = 'pt', role, badges } = Astro.props;

const {
  stockReliable: stockSignalsAreReliable,
  normalizedVariants: normalizedVariantsRaw,
  optionRows,
  defaultVariant,
  defaultVariantTitle,
} = getProductVariantData(product);

/** Card: `images` (2) + preços formatados para atualizar o DOM ao trocar variação. */
const normalizedVariants = normalizedVariantsRaw.map(
  ({ images, id, title, price, soldOut, maxQty, options, optionTitles, priceDisplay, originalDisplay, discountPercent }) => ({
    id,
    title,
    price,
    soldOut,
    maxQty,
    options,
    optionTitles,
    images,
    priceDisplay,
    originalDisplay,
    discountPercent,
  })
);

const variants = product.variants ?? [];
const priceInfo =
  normalizedVariantsRaw.find((n) => n.id === defaultVariant?.id) ?? normalizedVariantsRaw[0];
const priceVal = priceInfo?.priceDisplay ?? null;
const originalPriceVal = priceInfo?.originalDisplay ?? null;
const priceCents = priceInfo?.price ?? 0;
const isSoldOut = variants.length > 0
  ? variants.every((v: any) => isVariantSoldOut(v, stockSignalsAreReliable))
  : isVariantSoldOut(defaultVariant, stockSignalsAreReliable);
const discountPercent = priceInfo?.discountPercent ?? 0;
const exclusiveMeta = String(product.metadata?.exclusive ?? product.metadata?.is_exclusive ?? '').toLowerCase();
const isExclusive =
  exclusiveMeta === 'true' || exclusiveMeta === '1' || exclusiveMeta === 'yes' || exclusiveMeta === 'sim';
const hasPopularBadge = !!badges?.isPopular;
const hasNewBadge = !!badges?.isNew;
const handle = product.handle ?? '';

const [thumb, hoverThumb] = getVariantGalleryUrls(defaultVariant, product);

const selectedDefaultByOption = Object.fromEntries(
  (defaultVariant?.options ?? []).map((opt: any) => [String(opt.option_id ?? opt.id ?? ''), String(opt.value ?? '')])
);
---

<article
  class="pc"
  role={role ?? 'article'}
  data-variants={encodeURIComponent(JSON.stringify(normalizedVariants))}
  data-option-rows={encodeURIComponent(JSON.stringify(optionRows))}
>
  <a href={getPathForLang(`/product/${handle}`, lang)} class="pc__link" aria-label={product.title}>
    <div class="pc__img-wrap">
      <img
        src={thumb}
        alt={product.title ?? ''}
        class="pc__img pc__img--primary"
        width="480" height="480"
        loading="lazy" decoding="async"
      />
      <img
        src={hoverThumb || thumb}
        alt=""
        class="pc__img pc__img--secondary"
        data-has-secondary={hoverThumb ? 'true' : 'false'}
        width="480" height="480"
        loading="lazy"
        decoding="async"
        aria-hidden="true"
      />
      <div class="pc__tags pc__tags--priority">
        {isSoldOut ? (
          <span class="pc__tag pc__tag--soldout">
            <img src="/icons/cross.svg" alt="" width="12" height="12" />
            Sem estoque
          </span>
        ) : (
          <span class="pc__tag pc__tag--discount" style={discountPercent > 0 ? undefined : 'display:none'}>
            {discountPercent > 0 ? `${discountPercent}% off` : ''}
          </span>
        )}
      </div>
      <div class="pc__tags pc__tags--category">
        {!isSoldOut && isExclusive && <span class="pc__tag pc__tag--exclusive">Exclusivo</span>}
        {!isSoldOut && hasPopularBadge && (
          <span class="pc__tag pc__tag--popular">
            <img src="/icons/em-alta.svg" alt="" width="12" height="12" />
            Em alta
          </span>
        )}
        {!isSoldOut && hasNewBadge && (
          <span class="pc__tag pc__tag--new">
            <img src="/icons/novo.svg" alt="" width="12" height="12" />
            Novo
          </span>
        )}
      </div>
    </div>
  </a>

  <div class="pc__body">
    <a href={getPathForLang(`/product/${handle}`, lang)} class="pc__body-link">
      <h3 class="pc__name">{product.title}</h3>
    </a>
    
    {optionRows.length > 0 && (
      <div class="pc__variants">
        {optionRows.map((row: any) => (
          <div class="pc__variant-row">
            <div class="pc__variant-values" role="radiogroup" aria-label={row.title}>
              {row.values.map((val: string) => (
                <button
                  type="button"
                  class={`pc__variant-btn ${selectedDefaultByOption[row.id] === val ? 'is-selected' : ''}`}
                  data-option-id={row.id}
                  data-option-value={val}
                  aria-checked={selectedDefaultByOption[row.id] === val ? 'true' : 'false'}
                >
                  <span class="pc__variant-btn-text">{val}</span>
                  <span class="pc__variant-x">X</span>
                </button>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}
    <div class="pc__bottom">
      <div class={`pc__price-box${discountPercent > 0 ? ' pc__price-box--discount' : ''}`}>
        <span class="pc__price-striked" hidden={!originalPriceVal}>{originalPriceVal ?? ''}</span>
        {priceVal && <span class="pc__price-current">{priceVal}</span>}
      </div>
      
      <button
        type="button"
        class="pc__quick-add"
        data-variant-id={defaultVariant?.id}
        data-title={product.title}
        data-price={priceCents ?? ''}
        data-thumbnail={thumb}
        data-variant-title={defaultVariantTitle}
        data-max-qty={getVariantMaxQty(defaultVariant) ?? ''}
        disabled={isSoldOut}
        aria-label={`${t(lang, 'product', 'add_to_cart')} — ${product.title}`}
      >
        <img src="/icons/quick-cart.svg" alt="Add to cart" width="20" height="20" />
      </button>
    </div>
  </div>
</article>

<style>
.pc { display: flex; flex-direction: column; position: relative; transition: transform 0.3s ease; }
.pc:hover { transform: translateY(-4px); }
.pc__link { display: block; }
.pc__img-wrap { 
  position: relative; 
  aspect-ratio: 1; 
  overflow: hidden; 
  background: var(--c-bg-mute, #1a1a1a);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 8px;
  margin-bottom: 12px;
}
.pc__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.4,0,0.2,1), opacity 0.35s ease; }
.pc:hover .pc__img { transform: scale(1.06); }
.pc__img--secondary {
  position: absolute;
  inset: 0;
  opacity: 0;
  pointer-events: none;
}
.pc__img-wrap.is-hover-ready:hover .pc__img--secondary { opacity: 1; }
.pc__img-wrap.is-hover-ready:hover .pc__img--primary { opacity: 0; }

.pc__tags { position: absolute; left: 8px; display: flex; flex-direction: column; gap: 4px; }
.pc__tags--priority { top: 8px; }
.pc__tags--category { top: 8px; left: auto; right: 8px; align-items: flex-end; }
.pc__tag {
  font-size: 10px; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase;
  padding: 4px 10px; border-radius: var(--r);
  color: #fff; display: inline-flex; align-items: center; gap: 5px;
}
.pc__tag--soldout { background: #000; }
.pc__tag--discount { background: #16a34a; }
.pc__tag--exclusive { background: #6d28d9; }
.pc__tag--popular { background: #db2777; }
.pc__tag--new { background: var(--c-accent); color: #fff; }

.pc__body { text-align: center; display: flex; flex-direction: column; flex-grow: 1; }
.pc__body-link { text-decoration: none; display: block; flex-grow: 1; }
.pc__name {
  font-size: 14px; font-weight: 500; line-height: 1.3; color: var(--c-text);
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 2.6em;
}

.pc__bottom { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-top: auto; padding-bottom: 6px; }
.pc__price-box {
  display: inline-flex; flex-direction: row; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap; min-height: 20px;
}
.pc__price-striked { font-size: 12px; text-decoration: line-through; color: rgba(255,255,255,0.58); line-height: 1; }
.pc__price-current { font-size: 16px; font-weight: 800; color: #fff; line-height: 1; }
.pc__price-box--discount .pc__price-current { color: var(--c-accent); }

.pc__quick-add {
  position: static; transform: none;
  background: var(--c-surface2); border: 1px solid rgba(255,255,255,0.1); border-radius: 50%;
  width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all 0.2s ease;
}
.pc__quick-add:hover { background: var(--c-accent); border-color: var(--c-accent); }
.pc__quick-add:disabled { opacity: 0.7; cursor: not-allowed; border-color: rgba(248, 113, 113, 0.45); }
.pc__quick-add:disabled:hover { background: #991b1b; border-color: #ef4444; }

.pc__variants { display: flex; flex-direction: column; gap: 8px; margin-top: 10px; margin-bottom: 10px; }
.pc__variant-row { display: flex; align-items: center; justify-content: center; }
.pc__variant-values { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; }
.pc__variant-btn {
  border: 1px solid #d1d5db;
  border-radius: 999px;
  background: #fff;
  color: #111827;
  font-size: 11px;
  height: 28px;
  min-width: 36px;
  padding: 0 9px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  position: relative;
  overflow: hidden;
}
.pc__variant-btn:hover,
.pc__variant-btn.is-selected { border-color: var(--c-accent); background: var(--c-accent); color: #fff; }
.pc__variant-btn.is-unavailable { border-color: #cbd5e1; }
.pc__variant-btn-text { position: relative; z-index: 1; }
.pc__variant-x {
  display: none;
  position: absolute;
  inset: 0;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  color: #fff;
  font-size: 13px;
  font-weight: 800;
}
.pc__variant-btn.is-unavailable .pc__variant-x { display: flex; }
.pc__variant-btn.is-unavailable .pc__variant-btn-text { opacity: 0.18; }
</style>

<script>
  if (document.documentElement.dataset.pcInitDone !== 'true') {
    document.documentElement.dataset.pcInitDone = 'true';
    type VariantMap = {
      id: string;
      title: string;
      price: number;
      soldOut: boolean;
      maxQty?: number | null;
      options: Record<string, string>;
      images?: string[];
      priceDisplay?: string;
      originalDisplay?: string | null;
      discountPercent?: number;
    };
    type OptionRow = { id: string; title: string; values: string[] };
    type SelectedMap = Record<string, string>;

    const prefetchedImages = new Set<string>();
    const prefetchHoverImage = (url: string) => {
      if (!url || prefetchedImages.has(url)) return;
      prefetchedImages.add(url);
      const img = new Image();
      img.src = url;
    };

    const hoverImages = document.querySelectorAll('.pc__img--secondary');
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          if (el instanceof HTMLImageElement && el.currentSrc) {
            prefetchHoverImage(el.currentSrc);
          } else if (el instanceof HTMLImageElement && el.src) {
            prefetchHoverImage(el.src);
          }
          io.unobserve(el);
        });
      }, { rootMargin: '300px' });
      hoverImages.forEach((img) => io.observe(img));
    } else {
      hoverImages.forEach((img) => {
        if (img instanceof HTMLImageElement) prefetchHoverImage(img.src);
      });
    }

    const bindHoverReady = (img: HTMLImageElement) => {
      const parent = img.closest('.pc__img-wrap');
      if (!(parent instanceof HTMLElement)) return;
      if (img.dataset.hasSecondary !== 'true') {
        parent.classList.remove('is-hover-ready');
        return;
      }
      if (img.complete && img.naturalWidth > 0) {
        parent.classList.add('is-hover-ready');
      } else {
        img.addEventListener('load', () => parent.classList.add('is-hover-ready'), { once: true });
      }
      img.addEventListener('error', () => parent.classList.remove('is-hover-ready'), { once: true });
    };

    hoverImages.forEach((img) => {
      if (!(img instanceof HTMLImageElement)) return;
      bindHoverReady(img);
    });

    function decodeJson<T>(value: string): T | null {
      try { return JSON.parse(decodeURIComponent(value)) as T; } catch { return null; }
    }

    function variantMatches(variant: VariantMap, selected: SelectedMap): boolean {
      return Object.entries(selected).every(([k, v]) => !v || variant.options?.[k] === v);
    }

    function getFirstAvailable(variants: VariantMap[], selected: SelectedMap): VariantMap | null {
      return variants.find((v) => variantMatches(v, selected) && !v.soldOut) || null;
    }

    function initCard(card: Element) {
      if (!(card instanceof HTMLElement) || card.dataset.quickInit === '1') return;
      card.dataset.quickInit = '1';
      const secondary = card.querySelector('.pc__img--secondary');
      if (secondary instanceof HTMLImageElement) bindHoverReady(secondary);
      const quickBtn = card.querySelector('.pc__quick-add');
      if (!(quickBtn instanceof HTMLButtonElement)) return;
      const variants = decodeJson<VariantMap[]>(card.dataset.variants || '') || [];
      const optionRows = decodeJson<OptionRow[]>(card.dataset.optionRows || '') || [];
      if (!Array.isArray(variants) || !Array.isArray(optionRows) || !optionRows.length) return;
      const primaryImage = card.querySelector('.pc__img--primary');
      const secondaryImage = card.querySelector('.pc__img--secondary');
      const imgWrap = card.querySelector('.pc__img-wrap');
      const priceCurrent = card.querySelector('.pc__price-current');
      const priceStriked = card.querySelector('.pc__price-striked');
      const priceBox = card.querySelector('.pc__price-box');
      const discountTag = card.querySelector('.pc__tag--discount');
      const fallbackGallery = [quickBtn.dataset.thumbnail || '/logo.webp'].filter(Boolean);
      if (secondaryImage instanceof HTMLImageElement) {
        const secondarySrc = secondaryImage.getAttribute('src') || '';
        if (secondarySrc && secondarySrc !== fallbackGallery[0]) fallbackGallery.push(secondarySrc);
      }
      const allowedOptionIds = new Set(optionRows.map((row) => row.id));

      const selected: SelectedMap = {};
      const currentId = quickBtn.dataset.variantId || '';
      const current = variants.find((v) => v.id === currentId) || getFirstAvailable(variants, {}) || variants[0];
      if (current?.options) {
        Object.entries(current.options).forEach(([k, v]) => {
          if (!allowedOptionIds.has(k)) return;
          selected[k] = String(v || '');
        });
      }

      const applyGallery = (urls: string[]) => {
        const source = (Array.isArray(urls) && urls.length ? urls : fallbackGallery).slice(0, 2);
        const main = source[0] || '/logo.webp';
        const second = source[1] || '';
        if (primaryImage instanceof HTMLImageElement) {
          primaryImage.src = main;
        }
        if (secondaryImage instanceof HTMLImageElement) {
          secondaryImage.dataset.hasSecondary = second ? 'true' : 'false';
          secondaryImage.src = second || main;
          if (second) bindHoverReady(secondaryImage);
          else imgWrap?.classList.remove('is-hover-ready');
        }
        quickBtn.dataset.thumbnail = main;
      };

      const setFromVariant = (variant: VariantMap | null) => {
        if (!variant) return;
        quickBtn.dataset.variantId = variant.id || '';
        quickBtn.dataset.price = String(variant.price || 0);
        quickBtn.dataset.maxQty = Number.isFinite(Number(variant.maxQty)) ? String(Math.max(0, Math.floor(Number(variant.maxQty)))) : '';
        const optionTitle = optionRows
          .map((row) => {
            const val = String(selected[row.id] ?? variant.options?.[row.id] ?? '').trim();
            if (!val) return '';
            return `${row.title}: ${val}`;
          })
          .filter((s) => s.length > 0)
          .join(' | ');
        quickBtn.dataset.variantTitle = optionTitle || variant.title || '';
        quickBtn.disabled = !!variant.soldOut;
        applyGallery(variant.images || []);
        if (priceCurrent instanceof HTMLElement) {
          priceCurrent.textContent = variant.priceDisplay ?? '';
        }
        if (priceStriked instanceof HTMLElement) {
          if (variant.originalDisplay) {
            priceStriked.textContent = variant.originalDisplay;
            priceStriked.hidden = false;
          } else {
            priceStriked.textContent = '';
            priceStriked.hidden = true;
          }
        }
        if (priceBox instanceof HTMLElement) {
          priceBox.classList.toggle('pc__price-box--discount', (variant.discountPercent ?? 0) > 0);
        }
        if (discountTag instanceof HTMLElement) {
          const p = variant.discountPercent ?? 0;
          if (p > 0) {
            discountTag.textContent = `${p}% off`;
            discountTag.style.display = '';
          } else {
            discountTag.style.display = 'none';
          }
        }
      };

      const update = () => {
        optionRows.forEach((row: OptionRow) => {
          const rowBtns = card.querySelectorAll(`.pc__variant-btn[data-option-id="${row.id}"]`);
          rowBtns.forEach((btn) => {
            const value = btn.getAttribute('data-option-value') || '';
            const selectedForCheck = { ...selected, [row.id]: value };
            const hasAvailable = variants.some((v) => variantMatches(v, selectedForCheck) && !v.soldOut);
            btn.classList.toggle('is-selected', selected[row.id] === value);
            btn.classList.toggle('is-unavailable', !hasAvailable);
            btn.setAttribute('aria-checked', selected[row.id] === value ? 'true' : 'false');
          });
        });
        const matchedAvailable = getFirstAvailable(variants, selected);
        if (!matchedAvailable) {
          optionRows.forEach((row: OptionRow) => {
            const chosenValue = selected[row.id];
            if (!chosenValue) return;
            const hasAvailableForChosen = variants.some(
              (v) => !v.soldOut && String(v.options?.[row.id] ?? '') === chosenValue
            );
            if (!hasAvailableForChosen) selected[row.id] = '';
          });
        }
        const chosen =
          getFirstAvailable(variants, selected) ||
          variants.find((v) => !v.soldOut) ||
          variants.find((v) => variantMatches(v, selected)) ||
          variants[0];
        if (chosen) setFromVariant(chosen);
      };

      card.addEventListener('click', (ev) => {
        const t = ev.target;
        if (!(t instanceof Element)) return;
        const btn = t.closest('.pc__variant-btn');
        if (!(btn instanceof HTMLButtonElement)) return;
        if (btn.classList.contains('is-unavailable')) return;
        const optionId = btn.dataset.optionId || '';
        const optionValue = btn.dataset.optionValue || '';
        if (!optionId || !optionValue) return;
        selected[optionId] = optionValue;
        update();
      });
      update();
    }

    const allCards = document.querySelectorAll('.pc');
    allCards.forEach((card) => initCard(card));

    if ('MutationObserver' in window) {
      const mo = new MutationObserver((mutations) => {
        mutations.forEach((m) => {
          m.addedNodes.forEach((n) => {
            if (!(n instanceof HTMLElement)) return;
            if (n.matches?.('.pc')) initCard(n);
            n.querySelectorAll?.('.pc').forEach((c) => initCard(c));
          });
        });
      });
      mo.observe(document.body, { childList: true, subtree: true });
    }

    document.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;
      const btn = target.closest('.pc__quick-add');
      if (!btn) return;
      e.preventDefault();
      if (btn instanceof HTMLButtonElement && btn.disabled) return;
      const variantId = btn.getAttribute('data-variant-id');
      const title = btn.getAttribute('data-title') || '';
      const price = btn.getAttribute('data-price') || '0';
      const thumbnail = btn.getAttribute('data-thumbnail') || '';
      const variantTitle = btn.getAttribute('data-variant-title') || '';
      const maxQtyRaw = Number(btn.getAttribute('data-max-qty') || '');
      const maxQuantity = Number.isFinite(maxQtyRaw) && maxQtyRaw > 0 ? Math.floor(maxQtyRaw) : undefined;
      if (!variantId) return;
      import('../lib/cart').then(({ addItem }) => {
        addItem({ variantId, title, variantTitle, price: Number(price), thumbnail, quantity: 1, maxQuantity });
        document.getElementById('side-cart')?.classList.add('is-open');
        document.getElementById('side-cart-backdrop')?.classList.add('is-active');
        document.body.style.overflow = 'hidden';
      });
    });
  }
</script>
