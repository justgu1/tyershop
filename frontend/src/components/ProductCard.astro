---
import { t, getPathForLang, type Lang } from '../i18n/utils';
import { getVariantGalleryUrls } from '../lib/product-variant-gallery';
import { getProductVariantData, getVariantMaxQty, isVariantSoldOut } from '../lib/product-variants';
import { optionRowKind, optionRowShortLabel, swatchFillForValue } from '../lib/variant-option-ui';

interface Props {
  product: any;
  lang?: Lang;
  role?: 'article' | 'listitem';
  badges?: {
    isPopular?: boolean;
    isNew?: boolean;
  };
}

const { product, lang = 'pt', role, badges } = Astro.props;

const {
  stockReliable: stockSignalsAreReliable,
  normalizedVariants: normalizedVariantsRaw,
  optionRows,
  defaultVariant,
  defaultVariantTitle,
} = getProductVariantData(product);

const variants = product.variants ?? [];

const normalizedVariants = normalizedVariantsRaw.map(
  ({ images, id, title, price, soldOut, maxQty, options, optionTitles, priceDisplay, originalDisplay, discountPercent }) => {
    const raw = (variants as any[]).find((v) => String(v?.id) === String(id));
    return {
      id,
      title,
      price,
      soldOut,
      maxQty,
      options,
      optionTitles,
      images,
      priceDisplay,
      originalDisplay,
      discountPercent,
      allowBackorder: raw?.allow_backorder === true,
    };
  }
);

const priceInfo =
  normalizedVariantsRaw.find((n) => n.id === defaultVariant?.id) ?? normalizedVariantsRaw[0];
const priceVal = priceInfo?.priceDisplay ?? null;
const originalPriceVal = priceInfo?.originalDisplay ?? null;
const priceCents = priceInfo?.price ?? 0;
const isSoldOut = variants.length > 0
  ? variants.every((v: any) => isVariantSoldOut(v, stockSignalsAreReliable))
  : isVariantSoldOut(defaultVariant, stockSignalsAreReliable);
const discountPercent = priceInfo?.discountPercent ?? 0;
const exclusiveMeta = String(product.metadata?.exclusive ?? product.metadata?.is_exclusive ?? '').toLowerCase();
const isExclusive =
  exclusiveMeta === 'true' || exclusiveMeta === '1' || exclusiveMeta === 'yes' || exclusiveMeta === 'sim';
const hasPopularBadge = !!badges?.isPopular;
const hasNewBadge = !!badges?.isNew;
const handle = product.handle ?? '';
const stockNotifyMsgsEnc = encodeURIComponent(
  JSON.stringify({
    ok: t(lang, 'pdp', 'stock_notify_ok'),
    err: t(lang, 'pdp', 'stock_notify_err'),
  })
);

const [thumbRaw, hoverThumb] = getVariantGalleryUrls(defaultVariant, product);
const thumb = thumbRaw || '/no-data.webp';

const selectedDefaultByOption = Object.fromEntries(
  (defaultVariant?.options ?? []).map((opt: any) => [String(opt.option_id ?? opt.id ?? ''), String(opt.value ?? '')])
);

function partitionOptionRows(rows: typeof optionRows) {
  const colors: typeof optionRows = [];
  const sizes: typeof optionRows = [];
  const other: typeof optionRows = [];
  for (const row of rows) {
    const k = optionRowKind(row.title);
    if (k === 'color') colors.push(row);
    else if (k === 'size') sizes.push(row);
    else other.push(row);
  }
  return { colors, sizes, other };
}

const { colors: colorRows, sizes: sizeRows, other: otherOptRows } = partitionOptionRows(optionRows);
const showCorTamDivider = colorRows.length > 0 && sizeRows.length > 0;

type Section = { kind: 'divider' } | { kind: 'row'; row: (typeof optionRows)[0]; ui: 'swatch' | 'pill' };
const variantSections: Section[] = [];
for (const row of colorRows) variantSections.push({ kind: 'row', row, ui: 'swatch' });
if (showCorTamDivider) variantSections.push({ kind: 'divider' });
for (const row of sizeRows) variantSections.push({ kind: 'row', row, ui: 'pill' });
for (const row of otherOptRows) variantSections.push({ kind: 'row', row, ui: 'pill' });

---

<article
  class="pc"
  role={role ?? 'article'}
  data-stock-reliable={stockSignalsAreReliable ? 'true' : 'false'}
  data-product-id={product.id ?? ''}
  data-product-handle={handle}
  data-product-title={product.title ?? ''}
  data-stock-notify-msgs={stockNotifyMsgsEnc}
  data-variants={encodeURIComponent(JSON.stringify(normalizedVariants))}
  data-option-rows={encodeURIComponent(JSON.stringify(optionRows))}
>
  <a href={getPathForLang(`/product/${handle}`, lang)} class="pc__link" aria-label={product.title}>
    <div class="pc__img-wrap">
      <img
        src={thumb}
        alt={product.title ?? ''}
        class="pc__img pc__img--primary"
        width="480"
        height="480"
        loading="lazy"
        decoding="async"
        onerror="this.onerror=null;this.src='/no-data.webp'"
      />
      <img
        src={hoverThumb || thumb}
        alt=""
        class="pc__img pc__img--secondary"
        data-has-secondary={hoverThumb ? 'true' : 'false'}
        width="480"
        height="480"
        loading="lazy"
        decoding="async"
        aria-hidden="true"
        onerror="this.onerror=null;this.src='/no-data.webp'"
      />
      <div class="pc__tags pc__tags--priority">
        {isSoldOut ? (
          <span class="pc__tag pc__tag--soldout">
            <img src="/icons/cross.svg" alt="" width="12" height="12" />
            Sem estoque
          </span>
        ) : (
          <span class="pc__tag pc__tag--discount" style={discountPercent > 0 ? undefined : 'display:none'}>
            {discountPercent > 0 ? `${discountPercent}% off` : ''}
          </span>
        )}
      </div>
      <div class="pc__tags pc__tags--category">
        {!isSoldOut && isExclusive && <span class="pc__tag pc__tag--exclusive">Exclusivo</span>}
        {!isSoldOut && hasPopularBadge && (
          <span class="pc__tag pc__tag--popular">
            <img src="/icons/em-alta.svg" alt="" width="12" height="12" />
            Em alta
          </span>
        )}
        {!isSoldOut && hasNewBadge && (
          <span class="pc__tag pc__tag--new">
            <img src="/icons/novo.svg" alt="" width="12" height="12" />
            Novo
          </span>
        )}
      </div>
    </div>
  </a>

  <div class="pc__body">
    <a href={getPathForLang(`/product/${handle}`, lang)} class="pc__body-link">
      <h3 class="pc__name">{product.title}</h3>
    </a>

    {variantSections.length > 0 && (
      <div class="pc__variants">
        {variantSections.map((sec) => {
          if (sec.kind === 'divider') {
            return <div class="pc__variants-divider" role="presentation" aria-hidden="true" />;
          }
          const row = sec.row;
          const rk = optionRowKind(row.title);
          const shortL = optionRowShortLabel(row.title, rk);
          const safeHandle = String(handle || 'p').replace(/[^a-zA-Z0-9_-]/g, '');
          const safeRow = String(row.id || '').replace(/[^a-zA-Z0-9_-]/g, '');
          const headingId = `pc-h-${safeHandle}-${safeRow}` || 'pc-h';
          const sel = selectedDefaultByOption[row.id] ?? '';
          return (
            <div class="pc__variant-block" data-variant-block={row.id}>
              <p class="pc__variant-heading" id={headingId}>
                <span class="pc__variant-heading-k">{shortL}:</span>{' '}
                <span class="pc__variant-heading-value" data-heading-for={row.id}>
                  {sel || '—'}
                </span>
              </p>
              <div
                class:list={[
                  'pc__variant-values',
                  { 'pc__variant-values--swatch': sec.ui === 'swatch', 'pc__variant-values--pill': sec.ui === 'pill' },
                ]}
                role="radiogroup"
                aria-labelledby={headingId}
              >
                {sec.ui === 'swatch'
                  ? row.values.map((val: string) => {
                      const { fill, isGradient } = swatchFillForValue(val);
                      const isSel = selectedDefaultByOption[row.id] === val;
                      const isLight =
                        !!fill &&
                        !isGradient &&
                        ['#f5f5f5', '#ffffff', '#fff', '#f0f0f0', '#faf5eb'].includes(fill.toLowerCase());
                      const styleInner: { background?: string; backgroundColor?: string } = {};
                      if (isGradient && fill) styleInner.background = fill;
                      else if (fill) styleInner.backgroundColor = fill;
                      return (
                        <button
                          type="button"
                          class:list={[
                            'pc__variant-hit',
                            'pc__variant-hit--swatch',
                            { 'is-selected': isSel, 'pc__variant-hit--swatch-neutral': !fill, 'pc__variant-hit--swatch-light': isLight },
                          ]}
                          data-option-id={row.id}
                          data-option-value={val}
                          title={val}
                          aria-label={`${row.title}: ${val}`}
                          aria-checked={isSel ? 'true' : 'false'}
                        >
                          <span class="pc__variant-swatch-inner" style={styleInner} />
                        </button>
                      );
                    })
                  : row.values.map((val: string) => {
                      const isSel = selectedDefaultByOption[row.id] === val;
                      return (
                        <button
                          type="button"
                          class:list={['pc__variant-hit', 'pc__variant-hit--size', { 'is-selected': isSel }]}
                          data-option-id={row.id}
                          data-option-value={val}
                          aria-label={`${row.title}: ${val}`}
                          aria-checked={isSel ? 'true' : 'false'}
                        >
                          <span class="pc__variant-size-text">{val}</span>
                        </button>
                      );
                    })}
              </div>
            </div>
          );
        })}
      </div>
    )}

    <div class="pc__bottom">
      <div class:list={['pc__price-box', { 'pc__price-box--discount': discountPercent > 0 }]}>
        <span class="pc__price-striked" hidden={!originalPriceVal}>{originalPriceVal ?? ''}</span>
        {priceVal && <span class="pc__price-current">{priceVal}</span>}
      </div>

      <button
        type="button"
        class="pc__quick-add"
        data-variant-id={defaultVariant?.id}
        data-title={product.title}
        data-price={priceCents ?? ''}
        data-thumbnail={thumb}
        data-variant-title={defaultVariantTitle}
        data-max-qty={getVariantMaxQty(defaultVariant) ?? ''}
        disabled={isSoldOut}
        aria-label={`${t(lang, 'product', 'add_to_cart')} — ${product.title}`}
      >
        <img src="/icons/quick-cart.svg" alt="" width="20" height="20" />
      </button>
    </div>

    <div class="pc__stock-notify" hidden>
      <p class="pc__stock-notify__intro">{t(lang, 'pdp', 'stock_notify_intro')}</p>
      <div class="pc__stock-notify__row">
        <input
          type="email"
          class="pc__stock-notify__input"
          autocomplete="email"
          inputmode="email"
          placeholder="email@exemplo.com"
          aria-label={t(lang, 'pdp', 'stock_notify_email_aria')}
        />
        <button type="button" class="btn btn-outline pc__stock-notify__btn">
          {t(lang, 'pdp', 'stock_notify_cta')}
        </button>
      </div>
      <p class="pc__stock-notify__feedback" hidden role="status"></p>
    </div>
  </div>
</article>

<style>
.pc {
  display: flex;
  flex-direction: column;
  position: relative;
  height: 100%;
  min-height: 0;
  transition: transform 0.3s ease;
}
.pc:hover {
  transform: translateY(-4px);
}
.pc__link {
  display: block;
}
.pc__img-wrap {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  background: var(--c-bg-mute, #1a1a1a);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 8px;
  margin-bottom: 12px;
}
.pc__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.35s ease;
}
.pc:hover .pc__img {
  transform: scale(1.06);
}
.pc__img--secondary {
  position: absolute;
  inset: 0;
  opacity: 0;
  pointer-events: none;
}
.pc__img-wrap.is-hover-ready:hover .pc__img--secondary {
  opacity: 1;
}
.pc__img-wrap.is-hover-ready:hover .pc__img--primary {
  opacity: 0;
}

.pc__tags {
  position: absolute;
  left: 8px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.pc__tags--priority {
  top: 8px;
}
.pc__tags--category {
  top: 8px;
  left: auto;
  right: 8px;
  align-items: flex-end;
}
.pc__tag {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: var(--r);
  color: #fff;
  display: inline-flex;
  align-items: center;
  gap: 5px;
}
.pc__tag--soldout {
  background: #000;
}
.pc__tag--discount {
  background: #16a34a;
}
.pc__tag--exclusive {
  background: #0a0a0a;
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.12);
}
.pc__tag--popular {
  background: #0a0a0a;
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.12);
}
.pc__tag--popular img {
  filter: brightness(0) invert(1);
  opacity: 0.95;
}
.pc__tag--new {
  background: #0a0a0a;
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.12);
}
.pc__tag--new img {
  filter: brightness(0) invert(1);
  opacity: 0.95;
}

.pc__body {
  text-align: left;
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
}
.pc__body-link {
  text-decoration: none;
  display: block;
}
.pc__name {
  font-size: 14px;
  font-weight: 500;
  line-height: 1.3;
  color: var(--pc-name-color, var(--c-text));
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 2.6em;
}

.pc__variants {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 10px;
  margin-bottom: 10px;
}
.pc__variants-divider {
  height: 0;
  border: 0;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  margin: 2px 0 4px;
}
.pc__variant-block {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.pc__variant-heading {
  margin: 0;
  font-size: 12px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.3;
}
.pc__variant-heading-k {
  font-weight: 600;
  color: rgba(255, 255, 255, 0.72);
}
.pc__variant-heading-value {
  font-weight: 600;
  color: var(--c-text);
}

.pc__variant-values {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
}
.pc__variant-values--swatch {
  gap: 10px;
}

.pc__variant-hit {
  cursor: pointer;
  border: none;
  background: none;
  padding: 0;
  font: inherit;
}
.pc__variant-hit:focus-visible {
  outline: 2px solid var(--c-accent);
  outline-offset: 2px;
}

.pc__variant-hit--swatch {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 2px solid rgba(255, 255, 255, 0.22);
  transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
}
.pc__variant-hit--swatch:hover {
  transform: scale(1.06);
}
.pc__variant-hit--swatch.is-selected {
  border-color: var(--c-accent);
  box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.35);
}
.pc__variant-hit--swatch-neutral .pc__variant-swatch-inner {
  background-color: #9ca3af !important;
}
.pc__variant-hit--swatch-light {
  border-color: rgba(0, 0, 0, 0.2);
}
.pc__variant-hit--swatch-light.is-selected {
  border-color: var(--c-accent);
}
.pc__variant-swatch-inner {
  display: block;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  box-sizing: border-box;
  border: 1px solid rgba(0, 0, 0, 0.12);
}

.pc__variant-hit--size {
  min-width: 30px;
  height: 28px;
  padding: 0 7px;
  border-radius: var(--r-md, 6px);
  border: 1px solid rgba(255, 255, 255, 0.22);
  background: transparent;
  color: var(--c-text);
  font-size: 10px;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease, opacity 0.15s ease;
}
.pc__variant-hit--size:hover:not(:disabled):not(.is-unavailable) {
  border-color: rgba(255, 255, 255, 0.45);
}
.pc__variant-hit--size.is-selected {
  background: #0a0a0a;
  border-color: #0a0a0a;
  color: #fff;
}
.pc__variant-hit--size.is-unavailable {
  opacity: 0.38;
  cursor: not-allowed;
  border-color: rgba(255, 255, 255, 0.12);
}
.pc__variant-size-text {
  position: relative;
  text-decoration: none;
}
.pc__variant-hit--size.is-unavailable .pc__variant-size-text {
  text-decoration: line-through;
  text-decoration-thickness: 1.5px;
}

.pc__variant-hit--swatch.is-unavailable {
  opacity: 0.35;
  cursor: not-allowed;
}
.pc__variant-hit--swatch.is-unavailable .pc__variant-swatch-inner {
  position: relative;
}
.pc__variant-hit--swatch.is-unavailable .pc__variant-swatch-inner::after {
  content: '';
  position: absolute;
  inset: -2px;
  border-radius: 50%;
  background: linear-gradient(
    to top left,
    transparent calc(50% - 1px),
    rgba(0, 0, 0, 0.55) calc(50% - 1px),
    rgba(0, 0, 0, 0.55) calc(50% + 1px),
    transparent calc(50% + 1px)
  );
  pointer-events: none;
}

.pc__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-top: auto;
  padding-bottom: 6px;
}
.pc__bottom--oos .pc__price-box,
.pc__bottom--oos .pc__quick-add {
  display: none;
}

.pc__stock-notify {
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}
.pc__stock-notify__intro {
  margin: 0 0 8px;
  font-size: 12px;
  line-height: 1.35;
  color: rgba(255, 255, 255, 0.72);
}
.pc__stock-notify__row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: stretch;
}
.pc__stock-notify__input {
  flex: 1 1 140px;
  min-width: 0;
  padding: 8px 10px;
  border-radius: 8px;
  border: 1px solid rgba(255, 255, 255, 0.14);
  background: rgba(0, 0, 0, 0.25);
  color: #fff;
  font-size: 13px;
}
.pc__stock-notify__btn {
  flex: 0 0 auto;
  padding: 8px 12px;
  font-size: 12px;
  font-weight: 700;
}
.pc__stock-notify__feedback {
  margin: 8px 0 0;
  font-size: 12px;
}
.pc__stock-notify__feedback.is-ok {
  color: #7dffb2;
}
.pc__stock-notify__feedback.is-err {
  color: #ff8a8a;
}

.pc__price-box {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  gap: 8px;
  flex-wrap: wrap;
  min-height: 20px;
}
.pc__price-striked {
  font-size: 12px;
  text-decoration: line-through;
  color: var(--pc-price-striked, rgba(255, 255, 255, 0.58));
  line-height: 1;
}
.pc__price-current {
  font-size: 16px;
  font-weight: 800;
  color: var(--pc-price-current, #fff);
  line-height: 1;
}
.pc__price-box--discount .pc__price-current {
  color: var(--c-accent);
}

.pc__quick-add {
  position: static;
  transform: none;
  background: var(--c-surface2);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
  flex-shrink: 0;
}
.pc__quick-add img {
  filter: brightness(0) invert(1);
  opacity: 0.92;
}
.pc__quick-add:hover {
  background: #0a0a0a;
  border-color: #0a0a0a;
}
.pc__quick-add:hover img {
  filter: brightness(0) invert(1);
  opacity: 1;
}
.pc__quick-add:disabled {
  opacity: 0.7;
  cursor: not-allowed;
  border-color: rgba(248, 113, 113, 0.45);
}
.pc__quick-add:disabled:hover {
  background: #991b1b;
  border-color: #ef4444;
}
</style>
