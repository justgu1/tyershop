# Copie para `.env` na pasta `api/` (não commite segredos).
MERCADOPAGO_ACCESS_TOKEN=
# URL do Medusa vista a partir deste container (Docker: http://backend:9000)
MEDUSA_INTERNAL_URL=http://localhost:9003
# Mesma publishable key do storefront (só Store API — preços vêm do Medusa)
MEDUSA_PUBLISHABLE_KEY=
# E-mail que recebe pedidos de “avisar quando houver stock” (POST /api/stock-notify)
# STOCK_NOTIFY_TO=equipa@exemplo.com
# STOCK_NOTIFY_FROM=shop@exemplo.com
# URL pública da loja (redirect após pagamento MP). Em Docker local: http://localhost:4321
# CHECKOUT_PUBLIC_BASE_URL=https://tyer.com.br
# Checkout Pro: com `http://` o MP não aceita `auto_return` (redirecção automática). Em HTTPS (prod ou
# túnel tipo ngrok) define-se `auto_return`. Em http://localhost o fluxo continua sem redirecção automática.
